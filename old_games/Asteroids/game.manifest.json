{
  "$schema": "tools/schemas/game.manifest.schema.json",
  "schema": "html-js-gaming.game-manifest",
  "version": 1,
  "game": {
    "id": "Asteroids",
    "name": "Asteroids",
    "folder": "Asteroids"
  },
  "screen": {
    "width": 960,
    "height": 720
  },
  "launch": {
    "directPath": "/old_old_games/Asteroids/index.html",
    "workspaceManagerPath": "/tools/workspace-manager-v2/index.html?gameId=Asteroids",
    "workspaceManagerOptional": true
  },
  "tools": {
    "palette-manager-v2": {
      "$schema": "tools/schemas/tools/palette-manager-v2.schema.json",
      "schema": "html-js-gaming.palette",
      "version": 1,
      "name": "Asteroids Palette",
      "source": "manifest",
      "swatches": [
        {
          "symbol": "!",
          "hex": "#020617",
          "name": "Space Black",
          "source": "manifest"
        },
        {
          "symbol": "#",
          "hex": "#FFFFFF",
          "name": "Vector White",
          "source": "manifest"
        },
        {
          "symbol": "$",
          "hex": "#CBD5E1",
          "name": "Asteroid Gray",
          "source": "manifest"
        },
        {
          "symbol": "%",
          "hex": "#DBEAFE",
          "name": "Saucer Glow",
          "source": "manifest"
        },
        {
          "symbol": "&",
          "hex": "#94A3B8",
          "name": "HUD Muted",
          "source": "manifest"
        },
        {
          "symbol": ")",
          "hex": "#F87171",
          "name": "Warning Red",
          "source": "manifest"
        },
        {
          "symbol": "*",
          "hex": "#78B7FF",
          "name": "HUD Blue",
          "source": "manifest"
        },
        {
          "symbol": "+",
          "hex": "#FFBE64",
          "name": "HUD Gold",
          "source": "manifest"
        },
        {
          "symbol": "0",
          "hex": "#05070D",
          "name": "HUD Color 1",
          "source": "manifest"
        },
        {
          "symbol": "1",
          "hex": "#DCE8FF",
          "name": "HUD Color 2",
          "source": "manifest"
        }
      ]
    },
