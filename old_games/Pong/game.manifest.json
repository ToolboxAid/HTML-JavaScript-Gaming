{
  "$schema": "tools/schemas/game.manifest.schema.json",
  "schema": "html-js-gaming.game-manifest",
  "version": 1,
  "game": {
    "id": "Pong",
    "name": "Pong",
    "folder": "Pong"
  },
  "launch": {
    "directPath": "/old_old_games/Pong/index.html",
    "workspaceManagerPath": "/tools/workspace-manager-v2/index.html?gameId=Pong",
    "workspaceManagerOptional": true
  },
  "tools": {
    "palette-manager-v2": {
      "$schema": "tools/schemas/tools/palette-manager-v2.schema.json",
      "schema": "html-js-gaming.palette",
      "version": 1,
      "name": "Pong Classic Palette",
      "source": "manifest",
      "swatches": [
        {
          "symbol": "!",
          "hex": "#05070A",
          "name": "Background"
        },
        {
          "symbol": "#",
          "hex": "#F4F7FB",
          "name": "Ink / Paddles"
        },
        {
          "symbol": "$",
          "hex": "#A6B0BF",
          "name": "Muted HUD"
        },
        {
          "symbol": "%",
          "hex": "#7DE2FF",
          "name": "Accent"
        },
        {
          "symbol": "&",
          "hex": "#8BF0C8",
          "name": "Positive"
        },
        {
          "symbol": "(",
          "hex": "#FFD37D",
          "name": "Warning"
        },
        {
          "symbol": ")",
          "hex": "#FF9A9A",
          "name": "Danger"
        },
        {
          "symbol": "*",
          "hex": "#6A7482",
          "name": "Center Divider"
        }
      ]
    },
    "asset-manager-v2": {
      "$schema": "tools/schemas/tools/asset-manager-v2.schema.json",
      "schema": "html-js-gaming.asset-manager-v2",
      "version": 1,
      "name": "Pong Asset Manager V2 Registry",
      "source": "manifest",
      "assets": {
        "assets.image.preview.preview": {
          "path": "assets/images/preview1.svg",
          "type": "image",
          "kind": "svg",
          "role": "preview",
          "source": "manifest"
        }
      }
    },
    "input-mapping-v2": {
      "$schema": "tools/schemas/tools/input-mapping-v2.schema.json",
      "toolId": "input-mapping-v2",
      "version": 1,
      "engineInputModel": "src/engine/input/InputMap",
      "actions": [
        {
          "action": "playerMoveLeft",
          "label": "Player Move Left",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "KeyA:KeyboardHold",
              "label": "Keyboard KeyA Hold",
              "engine": "KeyboardState"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Button14:GameControllerDPad",
              "label": "Game Controller DPad Left DPad",
              "engine": "GamepadInputAdapter"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Axis0-:GameControllerStick",
              "label": "Game Controller Axis 0- Stick",
              "engine": "GamepadInputAdapter"
            }
          ]
        },
        {
          "action": "playerMoveRight",
          "label": "Player Move Right",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "KeyD:KeyboardHold",
              "label": "Keyboard KeyD Hold",
              "engine": "KeyboardState"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Button15:GameControllerDPad",
              "label": "Game Controller DPad Right DPad",
              "engine": "GamepadInputAdapter"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Axis0+:GameControllerStick",
              "label": "Game Controller Axis 0+ Stick",
              "engine": "GamepadInputAdapter"
            }
          ]
        },
        {
          "action": "playerMoveUp",
          "label": "Player Move Up",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "KeyW:KeyboardHold",
              "label": "Keyboard KeyW Hold",
              "engine": "KeyboardState"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Button12:GameControllerDPad",
              "label": "Game Controller DPad Up DPad",
              "engine": "GamepadInputAdapter"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Axis1-:GameControllerStick",
              "label": "Game Controller Axis 1- Stick",
              "engine": "GamepadInputAdapter"
            }
          ]
        },
        {
          "action": "playerMoveDown",
          "label": "Player Move Down",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "KeyS:KeyboardHold",
              "label": "Keyboard KeyS Hold",
              "engine": "KeyboardState"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Button13:GameControllerDPad",
              "label": "Game Controller DPad Down DPad",
              "engine": "GamepadInputAdapter"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Axis1+:GameControllerStick",
              "label": "Game Controller Axis 1+ Stick",
              "engine": "GamepadInputAdapter"
            }
          ]
        },
        {
          "action": "opponentMoveUp",
          "label": "Opponent Move Up",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "ArrowUp:KeyboardHold",
              "label": "Keyboard ArrowUp Hold",
              "engine": "KeyboardState"
            },
            {
              "source": "gamepad",
              "binding": "Pad1:Button12:GameControllerDPad",
              "label": "Game Controller DPad Up DPad",
              "engine": "GamepadInputAdapter"
            },
            {
              "source": "gamepad",
              "binding": "Pad1:Axis1-:GameControllerStick",
              "label": "Game Controller Axis 1- Stick",
              "engine": "GamepadInputAdapter"
            }
          ]
        },
        {
          "action": "opponentMoveDown",
          "label": "Opponent Move Down",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "ArrowDown:KeyboardHold",
              "label": "Keyboard ArrowDown Hold",
              "engine": "KeyboardState"
            },
            {
              "source": "gamepad",
              "binding": "Pad1:Button13:GameControllerDPad",
              "label": "Game Controller DPad Down DPad",
              "engine": "GamepadInputAdapter"
            },
            {
              "source": "gamepad",
              "binding": "Pad1:Axis1+:GameControllerStick",
              "label": "Game Controller Axis 1+ Stick",
              "engine": "GamepadInputAdapter"
            }
          ]
        },
        {
          "action": "serve",
          "label": "Serve",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "Space",
              "label": "Keyboard Space Press",
              "engine": "KeyboardState"
            },
            {
              "source": "keyboard",
              "binding": "Enter",
              "label": "Keyboard Enter Press",
              "engine": "KeyboardState"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Button0:GameControllerButtonPress",
              "label": "Game Controller Button 0 Btn Press",
              "engine": "GamepadInputAdapter"
            },
            {
              "source": "gamepad",
              "binding": "Pad1:Button0:GameControllerButtonPress",
              "label": "Game Controller Button 0 Btn Press",
              "engine": "GamepadInputAdapter"
            }
          ]
        },
        {
          "action": "pause",
          "label": "Pause",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "KeyP",
              "label": "Keyboard KeyP Press",
              "engine": "KeyboardState"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Button9:GameControllerButtonPress",
              "label": "Game Controller Button 9 Btn Press",
              "engine": "GamepadInputAdapter"
            },
            {
              "source": "gamepad",
              "binding": "Pad1:Button9:GameControllerButtonPress",
              "label": "Game Controller Button 9 Btn Press",
              "engine": "GamepadInputAdapter"
            }
          ]
        },
        {
          "action": "exit",
          "label": "Exit",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "KeyX",
              "label": "Keyboard KeyX Press",
              "engine": "KeyboardState"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Button1:GameControllerButtonPress",
              "label": "Game Controller Button 1 Btn Press",
              "engine": "GamepadInputAdapter"
            },
            {
              "source": "gamepad",
              "binding": "Pad1:Button1:GameControllerButtonPress",
              "label": "Game Controller Button 1 Btn Press",
              "engine": "GamepadInputAdapter"
            }
          ]
        },
        {
          "action": "nextMode",
          "label": "Next Mode",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "KeyM",
              "label": "Keyboard KeyM Press",
              "engine": "KeyboardState"
            },
            {
              "source": "keyboard",
              "binding": "Tab",
              "label": "Keyboard Tab Press",
              "engine": "KeyboardState"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Button5:GameControllerButtonPress",
              "label": "Game Controller Button 5 Btn Press",
              "engine": "GamepadInputAdapter"
            },
            {
              "source": "gamepad",
              "binding": "Pad1:Button5:GameControllerButtonPress",
              "label": "Game Controller Button 5 Btn Press",
              "engine": "GamepadInputAdapter"
            }
          ]
        },
        {
          "action": "previousMode",
          "label": "Previous Mode",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "KeyN",
              "label": "Keyboard KeyN Press",
              "engine": "KeyboardState"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Button4:GameControllerButtonPress",
              "label": "Game Controller Button 4 Btn Press",
              "engine": "GamepadInputAdapter"
            },
            {
              "source": "gamepad",
              "binding": "Pad1:Button4:GameControllerButtonPress",
              "label": "Game Controller Button 4 Btn Press",
              "engine": "GamepadInputAdapter"
            }
          ]
        }
      ]
    }
  }
}
