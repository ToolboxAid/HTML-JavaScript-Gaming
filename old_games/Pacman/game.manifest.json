{
  "$schema": "tools/schemas/game.manifest.schema.json",
  "schema": "html-js-gaming.game-manifest",
  "version": 1,
  "game": {
    "id": "Pacman",
    "name": "Pacman",
    "folder": "Pacman"
  },
  "launch": {
    "directPath": "/old_old_games/Pacman/index.html"
  },
  "tools": {
    "palette-manager-v2": {
      "$schema": "tools/schemas/tools/palette-manager-v2.schema.json",
      "schema": "html-js-gaming.palette",
      "version": 1,
      "name": "Pacman Full AI Palette",
      "source": "manifest",
      "swatches": [
        {
          "symbol": "!",
          "hex": "#020617",
          "name": "Background"
        },
        {
          "symbol": "#",
          "hex": "#020B1E",
          "name": "Maze Backdrop"
        },
        {
          "symbol": "$",
          "hex": "#1E3A8A",
          "name": "Maze Frame"
        },
        {
          "symbol": "%",
          "hex": "#1D4ED8",
          "name": "Wall Blue"
        },
        {
          "symbol": "&",
          "hex": "#38BDF8",
          "name": "Wall Highlight"
        },
        {
          "symbol": "(",
          "hex": "#FDE68A",
          "name": "Pellet"
        },
        {
          "symbol": ")",
          "hex": "#FEF9C3",
          "name": "Power Pellet"
        },
        {
          "symbol": "*",
          "hex": "#FACC15",
          "name": "Pacman Yellow"
        },
        {
          "symbol": "+",
          "hex": "#EF4444",
          "name": "Blinky Red"
        },
        {
          "symbol": ",",
          "hex": "#F472B6",
          "name": "Pinky Pink"
        },
        {
          "symbol": "-",
          "hex": "#22D3EE",
          "name": "Inky Cyan"
        },
        {
          "symbol": ".",
          "hex": "#FB923C",
          "name": "Clyde Orange"
        },
        {
          "symbol": "/",
          "hex": "#DBEAFE",
          "name": "Eaten Ghost"
        },
        {
          "symbol": "0",
          "hex": "#F8FAFC",
          "name": "Frightened Flash"
        },
        {
          "symbol": "1",
          "hex": "#E2E8F0",
          "name": "HUD Text"
        },
        {
          "symbol": "2",
          "hex": "#CBD5E1",
          "name": "Control Text"
        },
        {
          "symbol": "3",
          "hex": "#94A3B8",
          "name": "Muted Debug"
        },
        {
          "symbol": "4",
          "hex": "#334155",
          "name": "Debug Border"
        },
        {
          "symbol": "5",
          "hex": "#FECACA",
          "name": "Game Over Text"
        },
        {
          "symbol": "6",
          "hex": "#0F172A",
          "name": "Eye Detail"
        }
      ]
    },
    "asset-manager-v2": {
      "$schema": "tools/schemas/tools/asset-manager-v2.schema.json",
      "schema": "html-js-gaming.asset-manager-v2",
      "version": 1,
      "name": "Pacman Asset Manager V2 Registry",
      "source": "manifest",
      "assets": {
        "assets.image.preview.preview": {
          "path": "assets/images/preview.svg",
          "type": "image",
          "kind": "svg",
          "role": "preview",
          "source": "manifest"
        }
      }
    },
    "input-mapping-v2": {
      "$schema": "tools/schemas/tools/input-mapping-v2.schema.json",
      "toolId": "input-mapping-v2",
      "version": 1,
      "engineInputModel": "src/engine/input/InputMap",
      "actions": [
        {
          "action": "moveLeft",
          "label": "Move Left",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "ArrowLeft",
              "label": "Keyboard ArrowLeft Press",
              "engine": "KeyboardState"
            },
            {
              "source": "keyboard",
              "binding": "KeyA",
              "label": "Keyboard KeyA Press",
              "engine": "KeyboardState"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Button14:GameControllerDPad",
              "label": "Game Controller DPad Left DPad",
              "engine": "GamepadInputAdapter"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Axis0-:GameControllerStick",
              "label": "Game Controller Axis 0- Stick",
              "engine": "GamepadInputAdapter"
            }
          ]
        },
        {
          "action": "moveRight",
          "label": "Move Right",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "ArrowRight",
              "label": "Keyboard ArrowRight Press",
              "engine": "KeyboardState"
            },
            {
              "source": "keyboard",
              "binding": "KeyD",
              "label": "Keyboard KeyD Press",
              "engine": "KeyboardState"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Button15:GameControllerDPad",
              "label": "Game Controller DPad Right DPad",
              "engine": "GamepadInputAdapter"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Axis0+:GameControllerStick",
              "label": "Game Controller Axis 0+ Stick",
              "engine": "GamepadInputAdapter"
            }
          ]
        },
        {
          "action": "moveUp",
          "label": "Move Up",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "ArrowUp",
              "label": "Keyboard ArrowUp Press",
              "engine": "KeyboardState"
            },
            {
              "source": "keyboard",
              "binding": "KeyW",
              "label": "Keyboard KeyW Press",
              "engine": "KeyboardState"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Button12:GameControllerDPad",
              "label": "Game Controller DPad Up DPad",
              "engine": "GamepadInputAdapter"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Axis1-:GameControllerStick",
              "label": "Game Controller Axis 1- Stick",
              "engine": "GamepadInputAdapter"
            }
          ]
        },
        {
          "action": "moveDown",
          "label": "Move Down",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "ArrowDown",
              "label": "Keyboard ArrowDown Press",
              "engine": "KeyboardState"
            },
            {
              "source": "keyboard",
              "binding": "KeyS",
              "label": "Keyboard KeyS Press",
              "engine": "KeyboardState"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Button13:GameControllerDPad",
              "label": "Game Controller DPad Down DPad",
              "engine": "GamepadInputAdapter"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Axis1+:GameControllerStick",
              "label": "Game Controller Axis 1+ Stick",
              "engine": "GamepadInputAdapter"
            }
          ]
        },
        {
          "action": "start",
          "label": "Start",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "Enter",
              "label": "Keyboard Enter Press",
              "engine": "KeyboardState"
            },
            {
              "source": "keyboard",
              "binding": "Space",
              "label": "Keyboard Space Press",
              "engine": "KeyboardState"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Button0:GameControllerButtonPress",
              "label": "Game Controller Button 0 Btn Press",
              "engine": "GamepadInputAdapter"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Button9:GameControllerButtonPress",
              "label": "Game Controller Button 9 Btn Press",
              "engine": "GamepadInputAdapter"
            }
          ]
        },
        {
          "action": "reset",
          "label": "Reset",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "KeyR",
              "label": "Keyboard KeyR Press",
              "engine": "KeyboardState"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Button1:GameControllerButtonPress",
              "label": "Game Controller Button 1 Btn Press",
              "engine": "GamepadInputAdapter"
            }
          ]
        },
        {
          "action": "pause",
          "label": "Pause",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "KeyP",
              "label": "Keyboard KeyP Press",
              "engine": "KeyboardState"
            }
          ]
        }
      ]
    }
  }
}
