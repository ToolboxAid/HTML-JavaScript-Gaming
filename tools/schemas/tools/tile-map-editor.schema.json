{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tools/schemas/tools/tile-map-editor.schema.json",
  "title": "tile-map-editor Payload",
  "type": "object",
  "required": ["tool", "version", "payload"],
  "additionalProperties": false,
  "properties": {
    "tool": {
      "const": "tile-map-editor"
    },
    "version": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "integer",
          "minimum": 1
        }
      ]
    },
    "payload": {
      "type": "object",
      "required": [],
      "additionalProperties": false,
      "properties": {
        "tileMapDocument": {
          "$ref": "#/$defs/jsonValue"
        },
        "tilemapDocumentPath": {
          "$ref": "#/$defs/jsonValue"
        },
        "parallaxDocument": {
          "$ref": "#/$defs/jsonValue"
        }
      }
    }
  },
  "$defs": {
    "jsonValue": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "integer"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/jsonArray"
        },
        {
          "$ref": "#/$defs/jsonObject"
        }
      ]
    },
    "jsonArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/jsonValue"
      }
    },
    "jsonObject": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^.*$": {
          "$ref": "#/$defs/jsonValue"
        }
      },
      "propertyNames": {
        "type": "string"
      }
    }
  }
}
