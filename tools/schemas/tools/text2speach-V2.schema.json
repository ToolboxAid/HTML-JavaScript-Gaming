{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tools/schemas/tools/text2speach-V2.schema.json",
  "title": "Text to Speech V2 Payload",
  "type": "object",
  "required": ["$schema", "schema", "version", "name", "queue"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "const": "tools/schemas/tools/text2speach-V2.schema.json"
    },
    "schema": {
      "type": "string",
      "const": "html-js-gaming.text2speach-V2"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "queue": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/speechQueueItem"
      }
    }
  },
  "$defs": {
    "speechQueueItem": {
      "type": "object",
      "required": [
        "id",
        "name",
        "text",
        "gender",
        "language",
        "voice",
        "voiceAge",
        "volume",
        "rate",
        "pitch",
        "queueMode",
        "autoSpeak",
        "characterPreset",
        "ssmlLikePreset"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "gender": {
          "type": "string",
          "enum": ["any", "male-preferred", "female-preferred"]
        },
        "language": {
          "type": "string",
          "minLength": 2,
          "pattern": "^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$"
        },
        "voice": {
          "type": "string"
        },
        "voiceAge": {
          "type": "string",
          "enum": ["any", "adult", "child", "elderly", "teen"]
        },
        "volume": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "rate": {
          "type": "number",
          "minimum": 0.1,
          "maximum": 2
        },
        "pitch": {
          "type": "number",
          "minimum": 0.1,
          "maximum": 2
        },
        "queueMode": {
          "type": "string",
          "enum": ["append", "replace"]
        },
        "autoSpeak": {
          "type": "boolean"
        },
        "characterPreset": {
          "type": "string",
          "enum": ["manual", "alert", "calm", "dnd-dungeon-master", "dramatic", "narrator", "robot"]
        },
        "ssmlLikePreset": {
          "type": "string",
          "enum": ["normal", "slow", "whisper-ish"]
        }
      }
    }
  },
  "description": "Payload-only Text to Speech V2 schema for workspace-embeddable speech queue data."
}
