{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "object-vector-studio-v2.schema.json",
  "title": "Object Vector Studio V2 Durable Asset Payload",
  "description": "Strict durable asset data for Object Vector Studio V2. Runtime startup state and palette resources are loaded separately and are not stored in this payload.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "toolId", "name", "objects"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "toolId": {
      "const": "object-vector-studio-v2"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "objects": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/object"
      }
    }
  },
  "$defs": {
    "object": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "type", "shapes"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": ["actor", "enemy", "object", "pickup", "ship", "ui", "weapon"]
        },
        "shapes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/shape"
          }
        }
      }
    },
    "shape": {
      "oneOf": [
        {
          "$ref": "#/$defs/rectangleShape"
        },
        {
          "$ref": "#/$defs/circleShape"
        },
        {
          "$ref": "#/$defs/ellipseShape"
        },
        {
          "$ref": "#/$defs/lineShape"
        },
        {
          "$ref": "#/$defs/polygonShape"
        },
        {
          "$ref": "#/$defs/arcShape"
        },
        {
          "$ref": "#/$defs/textShape"
        }
      ]
    },
    "shapeCommon": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "order", "visible", "locked", "geometry", "style", "transform"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": ["rectangle", "circle", "ellipse", "line", "polygon", "arc", "text"]
        },
        "order": {
          "type": "integer",
          "minimum": 0
        },
        "visible": {
          "type": "boolean"
        },
        "locked": {
          "type": "boolean"
        },
        "geometry": {
          "type": "object"
        },
        "style": {
          "$ref": "#/$defs/style"
        },
        "transform": {
          "$ref": "#/$defs/transform"
        }
      }
    },
    "rectangleShape": {
      "allOf": [
        {
          "$ref": "#/$defs/shapeCommon"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "rectangle"
            },
            "geometry": {
              "$ref": "#/$defs/rectangleGeometry"
            }
          }
        }
      ]
    },
    "circleShape": {
      "allOf": [
        {
          "$ref": "#/$defs/shapeCommon"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "circle"
            },
            "geometry": {
              "$ref": "#/$defs/circleGeometry"
            }
          }
        }
      ]
    },
    "ellipseShape": {
      "allOf": [
        {
          "$ref": "#/$defs/shapeCommon"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "ellipse"
            },
            "geometry": {
              "$ref": "#/$defs/ellipseGeometry"
            }
          }
        }
      ]
    },
    "lineShape": {
      "allOf": [
        {
          "$ref": "#/$defs/shapeCommon"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "line"
            },
            "geometry": {
              "$ref": "#/$defs/lineGeometry"
            }
          }
        }
      ]
    },
    "polygonShape": {
      "allOf": [
        {
          "$ref": "#/$defs/shapeCommon"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "polygon"
            },
            "geometry": {
              "$ref": "#/$defs/polygonGeometry"
            }
          }
        }
      ]
    },
    "arcShape": {
      "allOf": [
        {
          "$ref": "#/$defs/shapeCommon"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "arc"
            },
            "geometry": {
              "$ref": "#/$defs/arcGeometry"
            }
          }
        }
      ]
    },
    "textShape": {
      "allOf": [
        {
          "$ref": "#/$defs/shapeCommon"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "text"
            },
            "geometry": {
              "$ref": "#/$defs/textGeometry"
            }
          }
        }
      ]
    },
    "style": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fill", "stroke", "strokeWidth"],
      "properties": {
        "fill": {
          "type": "string",
          "minLength": 1
        },
        "stroke": {
          "type": "string",
          "minLength": 1
        },
        "strokeWidth": {
          "type": "number",
          "minimum": 0
        },
        "opacity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "transform": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "rotation", "scaleX", "scaleY", "originX", "originY"],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "rotation": {
          "type": "number"
        },
        "scaleX": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "scaleY": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "originX": {
          "type": "number"
        },
        "originY": {
          "type": "number"
        }
      }
    },
    "point2d": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        }
      }
    },
    "rectangleGeometry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "width", "height"],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "width": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "height": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "circleGeometry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cx", "cy", "r"],
      "properties": {
        "cx": {
          "type": "number"
        },
        "cy": {
          "type": "number"
        },
        "r": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "ellipseGeometry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cx", "cy", "rx", "ry"],
      "properties": {
        "cx": {
          "type": "number"
        },
        "cy": {
          "type": "number"
        },
        "rx": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "ry": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "lineGeometry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x1", "y1", "x2", "y2"],
      "properties": {
        "x1": {
          "type": "number"
        },
        "y1": {
          "type": "number"
        },
        "x2": {
          "type": "number"
        },
        "y2": {
          "type": "number"
        }
      }
    },
    "polygonGeometry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["points"],
      "properties": {
        "points": {
          "type": "array",
          "minItems": 3,
          "items": {
            "$ref": "#/$defs/point2d"
          }
        }
      }
    },
    "arcGeometry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cx", "cy", "r", "startAngle", "endAngle"],
      "properties": {
        "cx": {
          "type": "number"
        },
        "cy": {
          "type": "number"
        },
        "r": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "startAngle": {
          "type": "number"
        },
        "endAngle": {
          "type": "number"
        }
      }
    },
    "textGeometry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "fontSize", "text"],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "fontSize": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "text": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
