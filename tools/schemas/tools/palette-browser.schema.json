{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tools/schemas/tools/palette-browser.schema.json",
  "title": "Palette Browser Payload",
  "type": "object",
  "required": [
    "tool",
    "version",
    "payload"
  ],
  "additionalProperties": false,
  "properties": {
    "tool": {
      "const": "palette-browser"
    },
    "version": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "integer",
          "minimum": 1
        }
      ]
    },
    "payload": {
      "type": "object",
      "required": [
        "schema",
        "version",
        "name",
        "swatches"
      ],
      "additionalProperties": false,
      "properties": {
        "schema": {
          "type": "string",
          "const": "html-js-gaming.palette"
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "sourceId": {
          "type": "string",
          "minLength": 1
        },
        "locked": {
          "type": "boolean"
        },
        "swatches": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "object",
            "required": [
              "symbol",
              "hex",
              "name"
            ],
            "additionalProperties": false,
            "properties": {
              "symbol": {
                "type": "string",
                "minLength": 1,
                "maxLength": 1
              },
              "hex": {
                "type": "string",
                "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{8})$"
              },
              "name": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  }
}
