{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tools/schemas/tools/asset-browser.schema.json",
  "title": "asset-browser Payload",
  "type": "object",
  "required": [
    "assets"
  ],
  "additionalProperties": false,
  "properties": {
    "assets": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^assets\\.image\\.bezel\\.[a-z0-9-]+(?:\\.[a-z0-9-]+)*$": {
          "$ref": "#/$defs/assetEntry"
        },
        "^(?!assets\\.image\\.bezel\\.[a-z0-9-]+(?:\\.[a-z0-9-]+)*$)assets\\.(image|audio|font|video|shader|data|localization)\\.[a-z0-9-]+\\.[a-z0-9-]+(?:\\.[a-z0-9-]+)*$": {
          "allOf": [
            {
              "$ref": "#/$defs/assetEntry"
            },
            {
              "not": {
                "required": [
                  "stretchOverride"
                ]
              }
            }
          ]
        }
      },
      "propertyNames": {
        "anyOf": [
          {
            "pattern": "^assets\\.image\\.bezel\\.[a-z0-9-]+(?:\\.[a-z0-9-]+)*$"
          },
          {
            "pattern": "^(?!assets\\.image\\.bezel\\.[a-z0-9-]+(?:\\.[a-z0-9-]+)*$)assets\\.(image|audio|font|video|shader|data|localization)\\.[a-z0-9-]+\\.[a-z0-9-]+(?:\\.[a-z0-9-]+)*$"
          }
        ]
      }
    },
    "assetBrowserPreset": {
      "$ref": "#/$defs/jsonValue"
    },
    "approvedAssets": {
      "$ref": "#/$defs/jsonValue"
    },
    "importHubPreset": {
      "$ref": "#/$defs/jsonValue"
    }
  },
  "$defs": {
    "assetEntry": {
      "type": "object",
      "required": [
        "path",
        "kind",
        "role",
        "source"
      ],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "image",
            "audio",
            "font",
            "video",
            "shader",
            "data",
            "localization"
          ]
        },
        "role": {
          "type": "string",
          "enum": [
            "sprite",
            "background",
            "bezel",
            "ui",
            "sound",
            "music",
            "display",
            "cutscene",
            "loop",
            "fragment",
            "vertex",
            "compute",
            "config",
            "table",
            "strings",
            "dialogue"
          ]
        },
        "source": {
          "type": "string",
          "enum": [
            "workspace-manager",
            "asset-browser",
            "asset-manager-v2",
            "manifest"
          ]
        },
        "stretchOverride": {
          "type": "object",
          "required": [
            "uniformEdgeStretchPx"
          ],
          "additionalProperties": false,
          "properties": {
            "uniformEdgeStretchPx": {
              "type": "number",
              "minimum": 0
            }
          }
        }
      }
    },
    "assetRolesByKind": {
      "image": [
        "sprite",
        "background",
        "bezel",
        "ui"
      ],
      "audio": [
        "sound",
        "music"
      ],
      "font": [
        "ui",
        "display"
      ],
      "video": [
        "cutscene",
        "loop"
      ],
      "shader": [
        "fragment",
        "vertex",
        "compute"
      ],
      "data": [
        "config",
        "table"
      ],
      "localization": [
        "strings",
        "dialogue"
      ]
    },
    "jsonValue": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "integer"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/jsonArray"
        },
        {
          "$ref": "#/$defs/jsonObject"
        }
      ]
    },
    "jsonArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/jsonValue"
      }
    },
    "jsonObject": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^.*$": {
          "$ref": "#/$defs/jsonValue"
        }
      },
      "propertyNames": {
        "type": "string"
      }
    }
  }
}
