{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tools/schemas/tools/asset-browser.schema.json",
  "title": "asset-browser Payload",
  "type": "object",
  "required": [
    "assets"
  ],
  "additionalProperties": false,
  "properties": {
    "assets": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^image\\.[a-z0-9-]+\\.[a-z0-9-]+(?:\\.[a-z0-9-]+)*\\.bezel$": {
          "$ref": "#/$defs/assetEntry"
        },
        "^(?!image\\.[a-z0-9-]+\\.[a-z0-9-]+(?:\\.[a-z0-9-]+)*\\.bezel$)(image|audio|font|svg|data|other)\\.[a-z0-9-]+\\.[a-z0-9-]+(?:\\.[a-z0-9-]+)*$": {
          "allOf": [
            {
              "$ref": "#/$defs/assetEntry"
            },
            {
              "not": {
                "required": [
                  "stretchOverride"
                ]
              }
            }
          ]
        }
      },
      "propertyNames": {
        "anyOf": [
          {
            "pattern": "^image\\.[a-z0-9-]+\\.[a-z0-9-]+(?:\\.[a-z0-9-]+)*\\.bezel$"
          },
          {
            "pattern": "^(?!image\\.[a-z0-9-]+\\.[a-z0-9-]+(?:\\.[a-z0-9-]+)*\\.bezel$)(image|audio|font|svg|data|other)\\.[a-z0-9-]+\\.[a-z0-9-]+(?:\\.[a-z0-9-]+)*$"
          }
        ]
      }
    },
    "assetBrowserPreset": {
      "$ref": "#/$defs/jsonValue"
    },
    "approvedAssets": {
      "$ref": "#/$defs/jsonValue"
    },
    "importHubPreset": {
      "$ref": "#/$defs/jsonValue"
    }
  },
  "$defs": {
    "assetEntry": {
      "type": "object",
      "required": [
        "path",
        "kind",
        "source"
      ],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "image",
            "audio",
            "font",
            "svg",
            "data",
            "other"
          ]
        },
        "source": {
          "type": "string",
          "enum": [
            "workspace-manager",
            "asset-browser",
            "manifest"
          ]
        },
        "stretchOverride": {
          "type": "object",
          "required": [
            "uniformEdgeStretchPx"
          ],
          "additionalProperties": false,
          "properties": {
            "uniformEdgeStretchPx": {
              "type": "number",
              "minimum": 0
            }
          }
        }
      }
    },
    "jsonValue": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "integer"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/jsonArray"
        },
        {
          "$ref": "#/$defs/jsonObject"
        }
      ]
    },
    "jsonArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/jsonValue"
      }
    },
    "jsonObject": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^.*$": {
          "$ref": "#/$defs/jsonValue"
        }
      },
      "propertyNames": {
        "type": "string"
      }
    }
  }
}
