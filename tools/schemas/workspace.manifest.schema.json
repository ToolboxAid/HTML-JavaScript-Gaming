{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tools/schemas/workspace.manifest.schema.json",
  "title": "Workspace Manifest",
  "type": "object",
  "required": ["documentKind", "schema", "version", "id", "name", "tools"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "documentKind": {
      "type": "string",
      "const": "workspace-manifest"
    },
    "schema": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "tools": {
      "type": "object",
      "required": [],
      "additionalProperties": false,
      "description": "Workspace-owned tool entry map keyed by canonical registry ids; payload schemas are referenced, never inlined here.",
      "properties": {
        "palette-browser": {
          "$ref": "./tools/palette-browser.schema.json"
        },
        "vector-map-editor": {
          "$ref": "./tools/vector-map-editor.schema.json"
        },
        "svg-asset-studio": {
          "$ref": "./tools/svg-asset-studio.schema.json"
        },
        "tile-map-editor": {
          "$ref": "./tools/tile-map-editor.schema.json"
        },
        "parallax-editor": {
          "$ref": "./tools/parallax-editor.schema.json"
        },
        "sprite-editor": {
          "$ref": "./tools/sprite-editor.schema.json"
        },
        "skin-editor": {
          "$ref": "./tools/skin-editor.schema.json"
        },
        "asset-browser": {
          "$ref": "./tools/asset-browser.schema.json"
        },
        "state-inspector": {
          "$ref": "./tools/state-inspector.schema.json"
        },
        "replay-visualizer": {
          "$ref": "./tools/replay-visualizer.schema.json"
        },
        "performance-profiler": {
          "$ref": "./tools/performance-profiler.schema.json"
        },
        "physics-sandbox": {
          "$ref": "./tools/physics-sandbox.schema.json"
        },
        "asset-pipeline": {
          "$ref": "./tools/asset-pipeline.schema.json"
        },
        "tile-model-converter": {
          "$ref": "./tools/tile-model-converter.schema.json"
        },
        "3d-json-payload": {
          "$ref": "./tools/3d-json-payload.schema.json"
        },
        "3d-asset-viewer": {
          "$ref": "./tools/3d-asset-viewer.schema.json"
        },
        "3d-camera-path-editor": {
          "$ref": "./tools/3d-camera-path-editor.schema.json"
        }
      }
    },
    "workspaceV2Session": {
      "type": "object",
      "required": ["schema", "defaultToolId", "activeToolId", "activeHostContextId", "toolSessions", "savedSessions", "exportedAt"],
      "additionalProperties": false,
      "properties": {
        "schema": {
          "type": "string",
          "const": "html-js-gaming.workspace-v2-session/1"
        },
        "defaultToolId": {
          "type": "string",
          "minLength": 1
        },
        "activeToolId": {
          "type": "string",
          "minLength": 1
        },
        "activeHostContextId": {
          "type": "string",
          "minLength": 1
        },
        "toolSessions": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^.*$": {
              "type": "object",
              "additionalProperties": false,
              "patternProperties": {
                "^.*$": {
                  "$ref": "#/$defs/jsonValue"
                }
              },
              "propertyNames": {
                "type": "string"
              }
            }
          },
          "propertyNames": {
            "type": "string"
          }
        },
        "savedSessions": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^.*$": {
              "$ref": "#/$defs/jsonValue"
            }
          },
          "propertyNames": {
            "type": "string"
          }
        },
        "exportedAt": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "$defs": {
    "jsonValue": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "integer"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/jsonArray"
        },
        {
          "$ref": "#/$defs/jsonObject"
        }
      ]
    },
    "jsonArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/jsonValue"
      }
    },
    "jsonObject": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^.*$": {
          "$ref": "#/$defs/jsonValue"
        }
      },
      "propertyNames": {
        "type": "string"
      }
    }
  }
}
