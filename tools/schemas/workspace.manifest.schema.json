{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tools/schemas/workspace.manifest.schema.json",
  "title": "Workspace Manifest",
  "type": "object",
  "required": ["documentKind", "schema", "version", "id", "name", "gameId", "gameRoot", "assetsPath", "tools"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "documentKind": {
      "type": "string",
      "const": "workspace-manifest"
    },
    "schema": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "gameId": {
      "type": "string",
      "minLength": 1
    },
    "gameRoot": {
      "type": "string",
      "pattern": "^games/[^/]+/$"
    },
    "assetsPath": {
      "type": "string",
      "pattern": "^games/[^/]+/assets$"
    },
    "screen": {
      "$ref": "#/$defs/screenDimensions"
    },
    "repoRoot": {
      "type": "string",
      "minLength": 1
    },
    "repoPath": {
      "type": "string",
      "minLength": 1,
      "description": "Absolute filesystem path to the repository root for workspace-owned direct writes. repoRoot remains the display label."
    },
    "tools": {
      "type": "object",
      "required": ["palette-manager-v2", "asset-manager-v2"],
      "additionalProperties": false,
      "description": "Workspace-owned tool entry map keyed by canonical registry ids; payload schemas are referenced, never inlined here.",
      "properties": {
        "palette-manager-v2": {
          "$ref": "./tools/palette-manager-v2.schema.json"
        },
        "svg-asset-studio": {
          "$ref": "./tools/svg-asset-studio.schema.json"
        },
        "tile-map-editor": {
          "$ref": "./tools/tile-map-editor.schema.json"
        },
        "parallax-editor": {
          "$ref": "./tools/parallax-editor.schema.json"
        },
        "sprite-editor": {
          "$ref": "./tools/sprite-editor.schema.json"
        },
        "asset-manager-v2": {
          "$ref": "./tools/asset-manager-v2.schema.json"
        },
        "object-vector-studio-v2": {
          "$ref": "./tools/object-vector-studio-v2.schema.json"
        },
        "collision-inspector-v2": {
          "$ref": "./tools/collision-inspector-v2.schema.json"
        },
        "state-inspector": {
          "$ref": "./tools/state-inspector.schema.json"
        },
        "replay-visualizer": {
          "$ref": "./tools/replay-visualizer.schema.json"
        },
        "performance-profiler": {
          "$ref": "./tools/performance-profiler.schema.json"
        },
        "physics-sandbox": {
          "$ref": "./tools/physics-sandbox.schema.json"
        },
        "asset-pipeline": {
          "$ref": "./tools/asset-pipeline.schema.json"
        },
        "3d-json-payload": {
          "$ref": "./tools/3d-json-payload.schema.json"
        },
        "3d-asset-viewer": {
          "$ref": "./tools/3d-asset-viewer.schema.json"
        },
        "3d-camera-path-editor": {
          "$ref": "./tools/3d-camera-path-editor.schema.json"
        },
        "text2speech-V2": {
          "$ref": "./tools/text2speech-V2.schema.json"
        }
      }
    }
  },
  "$defs": {
    "screenDimensions": {
      "type": "object",
      "required": ["width", "height"],
      "additionalProperties": false,
      "properties": {
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
