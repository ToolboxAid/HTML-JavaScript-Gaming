{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tools/schemas/workspace.manifest.schema.json",
  "title": "Workspace Manifest",
  "type": "object",
  "required": ["tools"],
  "additionalProperties": false,
  "properties": {
    "tools": {
      "type": "object",
      "required": ["palette"],
      "additionalProperties": true,
      "description": "Workspace-owned tool asset data. Palette is singular and canonical at tools.palette.",
      "properties": {
        "palette": {
          "type": "object",
          "required": ["id", "name", "swatches"],
          "additionalProperties": true,
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
            },
            "name": {
              "type": "string",
              "minLength": 1
            },
            "swatches": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["hex"],
                "additionalProperties": true,
                "properties": {
                  "symbol": {
                    "type": "string"
                  },
                  "hex": {
                    "type": "string",
                    "minLength": 4
                  },
                  "name": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
