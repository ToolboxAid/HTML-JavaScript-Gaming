{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tools/schemas/tool-states/audio-sfx-playground-v2.tool-state.schema.json",
  "title": "Audio / SFX Playground V2 Tool State",
  "description": "Exported toolState wrapper for Audio / SFX Playground V2. Saved sounds are the single source of truth; activeSoundId identifies the selected sound.",
  "type": "object",
  "required": ["$schema", "schema", "version", "toolId", "payload"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "const": "tools/schemas/tool-states/audio-sfx-playground-v2.tool-state.schema.json"
    },
    "schema": {
      "type": "string",
      "const": "html-js-gaming.tool-state"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "toolId": {
      "type": "string",
      "const": "audio-sfx-playground-v2"
    },
    "payload": {
      "$ref": "#/$defs/audioSfxPayload"
    }
  },
  "$defs": {
    "audioSfxPayload": {
      "type": "object",
      "required": ["schema", "version", "toolId", "activeSoundId", "sounds"],
      "additionalProperties": false,
      "properties": {
        "schema": {
          "type": "string",
          "const": "html-js-gaming.audio-sfx-playground-v2"
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "toolId": {
          "type": "string",
          "const": "audio-sfx-playground-v2"
        },
        "activeSoundId": {
          "type": "string",
          "minLength": 1
        },
        "sounds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/soundEntry"
          }
        }
      }
    },
    "soundEntry": {
      "type": "object",
      "required": ["id", "sound"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "sound": {
          "$ref": "#/$defs/sound"
        }
      }
    },
    "sound": {
      "type": "object",
      "required": ["attackMs", "durationMs", "frequencyHz", "name", "noise", "pitchSweepCents", "releaseMs", "volume", "waveform"],
      "additionalProperties": false,
      "properties": {
        "attackMs": {
          "type": "integer",
          "minimum": 0,
          "maximum": 250
        },
        "durationMs": {
          "type": "integer",
          "minimum": 60,
          "maximum": 1400
        },
        "frequencyHz": {
          "type": "integer",
          "minimum": 80,
          "maximum": 1800
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "noise": {
          "type": "boolean"
        },
        "pitchSweepCents": {
          "type": "integer",
          "minimum": -1200,
          "maximum": 1200
        },
        "releaseMs": {
          "type": "integer",
          "minimum": 20,
          "maximum": 700
        },
        "volume": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "waveform": {
          "type": "string",
          "enum": ["sine", "square", "triangle", "sawtooth"]
        }
      }
    }
  }
}
