{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tools/schemas/game.manifest.schema.json",
  "title": "Game Manifest",
  "description": "Schema for games/**/game.manifest.json as the single source of truth. game.gameData is the runtime contract. game.workspace is the editor/tool contract. Runtime code must ignore game.workspace. Tools may read game.gameData, may write game.workspace, and may update game.gameData only through explicit validated apply/build/export actions.",
  "type": "object",
  "required": ["schema", "version", "game"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "schema": {
      "type": "string",
      "const": "html-js-gaming.game-manifest"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "game": {
      "type": "object",
      "required": ["id", "name", "folder", "gameData", "workspace"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "folder": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[^/\\\\]+$"
        },
        "gameData": {
          "description": "Runtime contract for data the game needs to run. Editor/tool workspace state must not be required from this object.",
          "$ref": "#/$defs/gameData"
        },
        "workspace": {
          "description": "Editor/tool contract for workspace state needed to edit and build the game. Runtime code must ignore this object.",
          "$ref": "#/$defs/gameWorkspace"
        }
      }
    }
  },
  "$defs": {
    "gameData": {
      "type": "object",
      "description": "Runtime-only game data. Tools may read this object; writes are limited to explicit validated apply/build/export actions.",
      "required": ["launch"],
      "additionalProperties": true,
      "allOf": [
        {
          "not": {
            "required": ["workspace"]
          }
        },
        {
          "not": {
            "required": ["tools"]
          }
        }
      ],
      "properties": {
        "launch": {
          "type": "object",
          "required": ["directPath"],
          "additionalProperties": false,
          "properties": {
            "directPath": {
              "type": "string",
              "minLength": 1
            },
            "workspaceManagerPath": {
              "type": "string",
              "minLength": 1
            },
            "workspaceManagerOptional": {
              "type": "boolean"
            }
          }
        },
        "objectVectorRuntime": {
          "$ref": "#/$defs/objectVectorRuntime"
        }
      }
    },
    "objectIdentityId": {
      "type": "string",
      "description": "Runtime Object Vector identity. Runtime game references must use object IDs, not asset IDs or vector editor IDs.",
      "pattern": "^object\\.[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "objectVectorRuntime": {
      "type": "object",
      "description": "Runtime Object Vector references keyed by game semantic role. Values are object IDs, making object identity the runtime single source of truth.",
      "required": ["objectIds"],
      "additionalProperties": false,
      "properties": {
        "objectIds": {
          "type": "object",
          "description": "Map of game runtime roles to Object Vector object IDs.",
          "additionalProperties": {
            "$ref": "#/$defs/objectIdentityId"
          }
        }
      }
    },
    "gameWorkspace": {
      "type": "object",
      "description": "Editor/tool workspace state. Tools may write this object; runtime data belongs in game.gameData.",
      "required": ["documentKind", "schema", "version", "id", "name", "gameId", "gameRoot", "assetsPath", "tools"],
      "additionalProperties": false,
      "properties": {
        "$schema": {
          "type": "string",
          "minLength": 1
        },
        "documentKind": {
          "type": "string",
          "const": "workspace-manifest"
        },
        "schema": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "gameId": {
          "type": "string",
          "minLength": 1
        },
        "gameRoot": {
          "type": "string",
          "pattern": "^games/[^/]+/$"
        },
        "assetsPath": {
          "type": "string",
          "pattern": "^games/[^/]+/assets$"
        },
        "repoRoot": {
          "type": "string",
          "minLength": 1
        },
        "repoPath": {
          "type": "string",
          "minLength": 1
        },
        "tools": {
          "type": "object",
          "required": ["palette-manager-v2", "asset-manager-v2"],
          "properties": {
            "object-vector-studio-v2": {
              "$ref": "#/$defs/objectVectorStudioV2Payload"
            }
          },
          "additionalProperties": {
            "type": "object"
          }
        }
      }
    },
    "objectVectorStudioV2Payload": {
      "type": "object",
      "description": "Object Vector Studio V2 durable object geometry. Object IDs are runtime identity; shape rows use tool plus sorted local order for editor/runtime behavior.",
      "required": ["version", "toolId", "name", "objects"],
      "additionalProperties": false,
      "properties": {
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "toolId": {
          "const": "object-vector-studio-v2"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "objects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/objectVectorStudioObject"
          }
        },
        "assetLibrary": {
          "$ref": "#/$defs/objectVectorStudioAssetLibrary"
        }
      }
    },
    "objectVectorStudioAssetLibrary": {
      "type": "object",
      "required": ["assets"],
      "additionalProperties": false,
      "properties": {
        "assets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/objectVectorStudioLibraryAsset"
          }
        }
      }
    },
    "objectVectorStudioLibraryAsset": {
      "type": "object",
      "required": ["id", "name", "tags"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/objectIdentityId"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "$ref": "#/$defs/objectVectorStudioTags"
        }
      }
    },
    "objectVectorStudioObject": {
      "type": "object",
      "required": ["id", "name", "shapes"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/objectIdentityId"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "$ref": "#/$defs/objectVectorStudioTags"
        },
        "baseObjectId": {
          "$ref": "#/$defs/objectIdentityId"
        },
        "shapes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/objectVectorStudioShape"
          }
        },
        "states": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/objectVectorStudioState"
          }
        }
      }
    },
    "objectVectorStudioTags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "objectVectorStudioShape": {
      "type": "object",
      "required": ["tool", "order", "visible", "locked", "geometry", "style", "transform"],
      "additionalProperties": false,
      "properties": {
        "tool": {
          "type": "string",
          "enum": ["triangle", "rectangle", "circle", "ellipse", "line", "polygon", "arc", "text"]
        },
        "order": {
          "type": "integer",
          "minimum": 0
        },
        "visible": {
          "type": "boolean"
        },
        "locked": {
          "type": "boolean"
        },
        "groupId": {
          "type": "string",
          "minLength": 1
        },
        "geometry": {
          "type": "object",
          "additionalProperties": true
        },
        "style": {
          "$ref": "#/$defs/objectVectorStudioStyle"
        },
        "transform": {
          "$ref": "#/$defs/objectVectorStudioTransform"
        }
      }
    },
    "objectVectorStudioStyle": {
      "type": "object",
      "required": ["fill", "stroke", "strokeWidth"],
      "additionalProperties": false,
      "properties": {
        "fill": {
          "type": "string"
        },
        "stroke": {
          "type": "string"
        },
        "strokeWidth": {
          "type": "number",
          "minimum": 0
        },
        "opacity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "objectVectorStudioTransform": {
      "type": "object",
      "required": ["x", "y", "rotation", "scaleX", "scaleY", "originX", "originY"],
      "additionalProperties": false,
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "rotation": {
          "type": "number"
        },
        "scaleX": {
          "type": "number"
        },
        "scaleY": {
          "type": "number"
        },
        "originX": {
          "type": "number"
        },
        "originY": {
          "type": "number"
        }
      }
    },
    "objectVectorStudioState": {
      "type": "object",
      "required": ["id", "name", "frames"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "enum": ["idle", "thrust", "damaged", "destroyed", "active", "inactive"]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "frames": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/objectVectorStudioFrame"
          }
        }
      }
    },
    "objectVectorStudioFrame": {
      "type": "object",
      "required": ["id", "order", "durationFrames", "shapeOverrides"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "order": {
          "type": "integer",
          "minimum": 0
        },
        "durationFrames": {
          "type": "integer",
          "minimum": 1
        },
        "shapeOverrides": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/objectVectorStudioShapeOverride"
          }
        }
      }
    },
    "objectVectorStudioShapeOverride": {
      "type": "object",
      "required": ["shapeIndex"],
      "additionalProperties": false,
      "properties": {
        "shapeIndex": {
          "description": "Zero-based local sorted shape row index for the target shape.",
          "type": "integer",
          "minimum": 0
        },
        "visible": {
          "type": "boolean"
        },
        "transform": {
          "$ref": "#/$defs/objectVectorStudioTransform"
        }
      }
    }
  }
}
