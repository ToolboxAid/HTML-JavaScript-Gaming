{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tools/schemas/palette.schema.json",
  "title": "Shared Palette Document",
  "type": "object",
  "required": ["schema", "version", "name"],
  "properties": {
    "schema": { "const": "html-js-gaming.palette" },
    "version": { "type": "integer", "const": 1 },
    "name": { "type": "string" },
    "source": { "type": "string" },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["symbol", "hex", "name"],
        "properties": {
          "symbol": { "type": "string" },
          "hex": {
            "type": "string",
            "pattern": "^#([0-9A-Fa-f]{6}|[0-9A-Fa-f]{8})$"
          },
          "name": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "colors": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^#([0-9A-Fa-f]{6}|[0-9A-Fa-f]{8})$"
      }
    }
  },
  "additionalProperties": true
}
