{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tools/schemas/workspace.schema.json",
  "type": "object",
  "required": ["documentKind", "schema", "version", "games"],
  "additionalProperties": false,
  "properties": {
    "documentKind": {
      "type": "string",
      "const": "workspace-manifest"
    },
    "schema": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "games": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "level", "tool"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "level": {
            "type": "string",
            "minLength": 1
          },
          "tool": {
            "type": "string",
            "minLength": 1
          },
          "tools": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "palette": {
            "type": "string",
            "minLength": 1
          },
          "session": {
            "type": "object",
            "required": ["hostContextId", "payload"],
            "additionalProperties": false,
            "properties": {
              "hostContextId": {
                "type": "string",
                "minLength": 1
              },
              "payload": {
                "$ref": "#/$defs/jsonValue"
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "jsonValue": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "integer"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/jsonArray"
        },
        {
          "$ref": "#/$defs/jsonObject"
        }
      ]
    },
    "jsonArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/jsonValue"
      }
    },
    "jsonObject": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^.*$": {
          "$ref": "#/$defs/jsonValue"
        }
      },
      "propertyNames": {
        "type": "string"
      }
    }
  }
}
