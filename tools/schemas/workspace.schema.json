{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tools/schemas/workspace.schema.json",
  "type": "object",
  "required": ["documentKind", "schema", "version", "samples"],
  "additionalProperties": false,
  "properties": {
    "documentKind": {
      "type": "string",
      "const": "workspace-manifest"
    },
    "schema": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "samples": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "required": ["id", "type", "tool"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "minLength": 1
          },
          "phase": {
            "type": "string",
            "minLength": 1
          },
          "tool": {
            "type": "string",
            "minLength": 1
          },
          "tools": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "palette": {
            "type": "string",
            "minLength": 1
          }
        },
        "description": "id must be unique across samples."
      }
    }
  }
}
