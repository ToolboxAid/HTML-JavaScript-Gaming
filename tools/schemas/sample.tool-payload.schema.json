{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tools/schemas/sample.tool-payload.schema.json",
  "title": "Sample JSON Document",
  "type": "object",
  "required": [
    "$schema"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "sampleId": {
      "type": "string",
      "minLength": 1
    },
    "phase": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "toolHints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "payload": {
      "$ref": "#/$defs/jsonObject"
    },
    "runtime": {
      "$ref": "#/$defs/jsonObject"
    },
    "toolState": {
      "$ref": "#/$defs/jsonObject"
    },
    "provenance": {
      "$ref": "#/$defs/jsonObject"
    }
  },
  "allOf": [
    {
      "if": {
        "required": [
          "sampleId"
        ]
      },
      "then": {
        "required": [
          "sampleId",
          "phase",
          "title",
          "description",
          "toolHints",
          "payload",
          "runtime",
          "toolState",
          "provenance"
        ]
      }
    }
  ],
  "$defs": {
    "jsonValue": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "integer"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/jsonArray"
        },
        {
          "$ref": "#/$defs/jsonObject"
        }
      ]
    },
    "jsonArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/jsonValue"
      }
    },
    "jsonObject": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^.*$": {
          "$ref": "#/$defs/jsonValue"
        }
      },
      "propertyNames": {
        "type": "string"
      }
    }
  }
}
