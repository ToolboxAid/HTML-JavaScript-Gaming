{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "toolbox/schemas/samples/sample.tool-payload.schema.json",
  "title": "Sample Data Wrapper (Non-Tool Payload)",
  "description": "Strict sample data wrapper schema for sample metadata/doc artifacts. Tool runtime payloads must validate against tool-specific schemas under toolbox/schemas/tools/*.schema.json.",
  "type": "object",
  "required": ["$schema", "schema", "version"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "schema": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "integer",
          "minimum": 1
        }
      ]
    }
  },
  "patternProperties": {
    "^(?!\\$schema$|schema$|version$).+": {
      "$ref": "#/$defs/jsonValue"
    }
  },
  "$defs": {
    "jsonValue": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "integer"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/jsonArray"
        },
        {
          "$ref": "#/$defs/jsonObject"
        }
      ]
    },
    "jsonArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/jsonValue"
      }
    },
    "jsonObject": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^.*$": {
          "$ref": "#/$defs/jsonValue"
        }
      },
      "propertyNames": {
        "type": "string"
      }
    }
  },
  "not": {
    "required": ["tool", "payload"]
  }
}
