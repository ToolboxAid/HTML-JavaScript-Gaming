-    if (!value || !/color\(/i.test(value)) continue;
-    style.setProperty(
-      property,
-      replaceUnsupportedColorFunctions(value),
-      style.getPropertyPriority(property)
-    );
-  }
-
-  const bg = style.backgroundImage || "";
-  if (/gradient/i.test(bg)) {
-    style.backgroundImage = "none";
-  }
-}
