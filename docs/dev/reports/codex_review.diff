+    result += source.slice(index, matchIndex);
+    let cursor = matchIndex + "color(".length;
+    let depth = 1;
+    while (cursor < source.length && depth > 0) {
+      const char = source[cursor];
+      if (char === "(") depth += 1;
+      if (char === ")") depth -= 1;
+      cursor += 1;
+    }
