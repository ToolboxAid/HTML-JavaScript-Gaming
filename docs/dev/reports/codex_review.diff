+    }
+    fontSet.add(loadedFontFace);
+    previewText?.setAttribute("data-preview-font-loaded", "true");
+  } catch (error) {
+    if (target.dataset.previewAssetId !== model.assetId) {
+      return;
+    }
+    options.onPreviewStatus?.("fail", fontLoadErrorMessage(model, error));
