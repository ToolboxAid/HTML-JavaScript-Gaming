+.tools-platform-frame__eyebrow {
+  font-size: clamp(0.96rem, 1.2vw, 1.06rem);
+}
+
+.tools-platform-frame__meta,
+.tools-platform-frame__description,
+.tools-platform-statusbar {
+  font-size: var(--tools-type-meta);
+}
+
+.tools-platform-frame__topline {
+  min-width: 0;
+  max-width: 100%;
+}
+
+.tools-platform-statusbar {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 12px;
+  flex-wrap: wrap;
+  padding: 8px 12px;
+  color: var(--muted, #e9ddff);
+}
+
+body.tools-platform-surface .preview-generator-v2.app-shell {
+  width: min(1600px, calc(100% - 32px));
+  margin: 0 auto 16px;
+  border: 1px solid var(--line, rgba(221, 214, 254, 0.26));
+  border-radius: 20px;
+  box-shadow: var(--tools-shell-shadow-strong);
