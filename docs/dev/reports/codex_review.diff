+}
+
+@media (min-width: 1201px) {
+  body.tools-platform-surface .tools-platform-resize-panel {
+    min-width: 240px;
+    max-width: min(42vw, 560px);
+    resize: horizontal;
+    overflow: auto;
+  }
+}
+
+@media (max-width: 1200px) {
+  body.tools-platform-surface .tools-platform-resize-panel {
+    max-width: none;
+    max-height: none;
+    resize: none;
+  }
+}
