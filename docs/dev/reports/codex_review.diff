+body.tools-platform-tool-page[data-tool-id="preview-generator-v2"] {
+  min-height: 100vh;
+  min-height: 100dvh;
+  display: flex;
+  flex-direction: column;
+  overflow-y: auto;
+  overflow-x: hidden;
+}
+
+body.tools-platform-tool-page[data-tool-id="preview-generator-v2"] > .is-collapsible,
+body.tools-platform-tool-page[data-tool-id="preview-generator-v2"] > .preview-generator-v2__menu-sample,
+body.tools-platform-tool-page[data-tool-id="preview-generator-v2"] > [data-preview-generator-v2-status] {
