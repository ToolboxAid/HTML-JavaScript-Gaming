-    return false;
-  }
-  const documentKind = normalizeTextParam(rawSource.documentKind);
-  const schema = normalizeTextParam(rawSource.schema).toLowerCase();
-  return documentKind === WORKSPACE_DOCUMENT_KIND || schema === WORKSPACE_MANIFEST_SCHEMA;
