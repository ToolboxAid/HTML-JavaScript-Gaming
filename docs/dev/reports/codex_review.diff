+  font-size: var(--tools-type-body);
+  line-height: 1.45;
+  letter-spacing: 0.005em;
+}
+
+[data-preview-generator-v2-header],
+[data-preview-generator-v2-status] {
+  display: block;
+  width: calc(100% - 32px);
+  margin: 10px auto;
+}
+
+[data-preview-generator-v2-header] {
+  width: calc(100% - 140px);
+}
+
+.tools-platform-frame,
+.tools-platform-statusbar {
+  border: 1px solid var(--line, rgba(221, 214, 254, 0.26));
