+function extractBestToolFallbackSvg(doc) {
+  const preferredSelectors = [
+    "main canvas",
+    ".editor canvas",
+    ".workspace canvas",
+    "#editor canvas",
+    "canvas",
+    "main",
+    ".editor",
+    ".workspace",
+    "#editor",
+    "body"
+  ];
