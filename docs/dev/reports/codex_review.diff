-
-function getExplicitColorValue(entry) {
-  if (typeof entry === "string") {
-    return normalizeHexColor(entry);
-  }
-  if (!isPlainObject(entry)) {
-    return "";
-  }
-  return normalizeHexColor(entry.hex);
