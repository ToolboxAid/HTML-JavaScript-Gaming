-    .split(/\r?\n/)
-    .map(x => x.trim())
-    .filter(Boolean);
-
-  const unique = [];
-  const seen = new Set();
-
-  for (const line of lines) {
-    const key = line.toLowerCase();
-    if (!seen.has(key)) {
-      seen.add(key);
-      unique.push(line);
-    }
-  }
-
-  return unique;
-}
