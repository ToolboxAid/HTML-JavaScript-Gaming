+        summary.style.maxWidth = "calc(100vw - 24px)";
+        summary.style.whiteSpace = "nowrap";
+        summary.style.overflow = "hidden";
+        summary.style.textOverflow = "ellipsis";
+      } else {
+        summary.style.removeProperty("max-width");
+        summary.style.removeProperty("white-space");
+        summary.style.removeProperty("overflow");
+        summary.style.removeProperty("text-overflow");
+      }
+
+      summary.setAttribute("data-tools-platform-summary-active", "1");
+      summary.setAttribute("data-tools-platform-summary-error", "0");
+      summary.setAttribute("data-tools-platform-summary-state", isExpanded ? "expanded" : "collapsed");
+      summary.setAttribute("data-tools-platform-summary-mode", isFullscreen ? "fullscreen" : "normal");
+      summary.setAttribute("data-tool-id", PREVIEW_GENERATOR_TOOL_ID);
+      summary.setAttribute("title", `${PREVIEW_GENERATOR_HEADER_TEXT}\n${PREVIEW_GENERATOR_INTRO_TEXT}`);
+    }
+
+    async function enterPreviewGeneratorFullscreenIfAvailable() {
+      if (document.fullscreenElement || !document.fullscreenEnabled) {
+        return;
+      }
+      if (typeof document.documentElement?.requestFullscreen !== "function") {
+        return;
+      }
+      try {
+        await document.documentElement.requestFullscreen();
+      } catch {
+        // Non-fatal: collapsed header state remains usable without fullscreen.
+      }
+    }
+
+    async function exitPreviewGeneratorFullscreenIfActive() {
+      if (!document.fullscreenElement || typeof document.exitFullscreen !== "function") {
+        return;
+      }
+      try {
+        await document.exitFullscreen();
+      } catch {
+        // Non-fatal: the fullscreenchange listener will resync if the browser exits later.
+      }
+    }
+
+    function bindPreviewGeneratorHeaderDetails() {
+      const details = getPreviewGeneratorHeaderDetails();
+      if (!(details instanceof HTMLDetailsElement)) {
+        return;
+      }
+
+      details.addEventListener("toggle", () => {
+        updatePreviewGeneratorSummary();
+        if (suppressPreviewGeneratorFullscreenSync) {
+          suppressPreviewGeneratorFullscreenSync = false;
+          return;
+        }
+
+        if (details.open) {
+          void exitPreviewGeneratorFullscreenIfActive();
+          return;
+        }
+
+        void enterPreviewGeneratorFullscreenIfAvailable();
+      });
+
+      document.addEventListener("fullscreenchange", () => {
+        const isFullscreen = Boolean(document.fullscreenElement);
+        applyPreviewGeneratorFullscreenState(isFullscreen);
+        if (!isFullscreen && !details.open) {
+          suppressPreviewGeneratorFullscreenSync = true;
+          details.open = true;
+        }
+        updatePreviewGeneratorSummary();
+      });
+    }
+
+    function initPreviewGeneratorShell() {
+      if (previewGeneratorRuntimeParams.get("mode") === "runtime") {
+        return;
+      }
+
+      document.body.classList.add("tools-platform-surface", "preview-generator-v2-local-shell");
+      applyPreviewGeneratorFullscreenState(Boolean(document.fullscreenElement));
+      bindPreviewGeneratorHeaderDetails();
+      updatePreviewGeneratorSummary();
+    }
+
+    initPreviewGeneratorShell();
+  </script>
