-    const rawPreset = await response.json();
-    await logToolLoadLoaded({
-      toolId: "palette-browser",
-      toolName: "Palette Browser / Manager",
-      sampleId,
-      samplePresetPath,
-      requestedPath: samplePresetPath,
-      fetchUrl: presetHref,
