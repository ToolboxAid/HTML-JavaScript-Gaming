+const UNSUPPORTED_COLOR_FUNCTION_PROPERTIES = [
+  "background",
+  "background-color",
+  "border-block-color",
+  "border-block-end-color",
+  "border-block-start-color",
+  "border-bottom-color",
+  "border-color",
+  "border-inline-color",
+  "border-inline-end-color",
+  "border-inline-start-color",
+  "border-left-color",
+  "border-right-color",
+  "border-top-color",
+  "box-shadow",
+  "caret-color",
+  "color",
+  "column-rule-color",
+  "fill",
+  "outline-color",
+  "scrollbar-color",
+  "stop-color",
+  "stroke",
+  "text-decoration-color",
+  "text-emphasis-color",
+  "text-shadow"
