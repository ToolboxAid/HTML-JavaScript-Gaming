+      drawSourceCanvas(sourceCanvas);
+      setRuntimeStatus("ready");
+    } catch {
+      if (Date.now() - startTime > timeoutMs) {
+        fail("Capture timeout");
+        return;
+      }
+      requestAnimationFrame(() => {
