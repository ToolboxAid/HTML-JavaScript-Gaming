+async function getExistingDirectoryPath(parentHandle, relativePath) {
+  const parts = String(relativePath || "")
+    .replaceAll("\\", "/")
+    .split("/")
+    .map(x => x.trim())
+    .filter(Boolean);
+
+  let current = parentHandle;
+  for (const part of parts) {
+    current = await current.getDirectoryHandle(part);
+  }
+  return current;
+}
