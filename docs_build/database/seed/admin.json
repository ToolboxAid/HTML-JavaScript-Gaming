{
  "group": "Admin",
  "groupKey": "admin",
  "owner": "docs_build/database/seed",
  "serverSideSeedRequired": true,
  "browserAuthoritativeKeyGenerationAllowed": false,
  "tables": {
    "platform_settings": {
      "mode": "server-api-generated-keys",
      "starterRows": [
        {
          "settingKey": "site.setup.status",
          "settingType": "string",
          "settingValue": "ready"
        },
        {
          "settingKey": "platform.banner.enabled",
          "settingType": "boolean",
          "settingValue": "false"
        },
        {
          "settingKey": "platform.banner.message",
          "settingType": "string",
          "settingValue": ""
        },
        {
          "settingKey": "platform.banner.tone",
          "settingType": "string",
          "settingValue": "info"
        },
        {
          "settingKey": "platform.banner.kind",
          "settingType": "string",
          "settingValue": "general"
        }
      ]
    }
  },
  "note": "Admin Site Setup owns explicit server-side setup/reseed entry points and platform settings bootstrap."
}
