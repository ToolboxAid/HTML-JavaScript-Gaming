++++    throw new Error(`Local DB table ${tableName} is missing. ${LOCAL_DB_START_ACTION}`);
++++  }
++++  return rows;
++++}
++++
++++function tableSchema(snapshot, tableName) {
++++  const schema = snapshot?.schemas?.[tableName];
++++  if (!Array.isArray(schema)) {
