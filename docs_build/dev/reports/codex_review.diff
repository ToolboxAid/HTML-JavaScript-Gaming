-function saveHitboxes() {
-  const object = selectedObjectA();
-  if (!object) {
-    state.saveStatus = "Select Object A before saving.";
-    renderStatus();
-    return;
-  }
-  const validationMessage = validateHitboxes();
-  if (validationMessage) {
-    state.saveStatus = validationMessage;
-    renderStatus();
-    return;
