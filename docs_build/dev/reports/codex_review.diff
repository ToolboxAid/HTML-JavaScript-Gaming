+  }
+  const normalized = normalizeHealthStatus(status);
+  if (normalized === "PASS") {
+    return { healthStatus: "PASS", status: "Healthy" };
+  }
+  if (normalized === "FAIL") {
+    return { healthStatus: "FAIL", status: "Failed" };
+  }
+  return { healthStatus: "WARN", status: "Warning" };
+}
