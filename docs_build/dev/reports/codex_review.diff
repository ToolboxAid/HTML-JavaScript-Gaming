+  if ((quote === "\"" || quote === "'") && trimmed.endsWith(quote)) {
+    return trimmed.slice(1, -1);
+  }
+  const commentIndex = trimmed.indexOf(" #");
+  return commentIndex === -1 ? trimmed : trimmed.slice(0, commentIndex).trim();
