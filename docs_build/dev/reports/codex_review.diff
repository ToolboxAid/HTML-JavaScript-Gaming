-function motionBox() {
-  const hitbox = selectedHitbox();
-  const object = selectedObjectA();
-  const width = hitbox?.width || object?.bounds?.width || 10;
-  const height = hitbox?.height || object?.bounds?.height || 10;
-  return {
-    height,
-    width,
-    x: state.motion.startX,
-    y: state.motion.startY,
-  };
