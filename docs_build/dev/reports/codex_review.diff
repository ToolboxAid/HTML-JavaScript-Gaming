+}
+
+function formatToolSlug(slug) {
+  return String(slug || "Tool")
+    .split(/[-_\s]+/)
+    .filter(Boolean)
+    .map((part) => `${part.charAt(0).toUpperCase()}${part.slice(1)}`)
+    .join(" ") || "Tool";
