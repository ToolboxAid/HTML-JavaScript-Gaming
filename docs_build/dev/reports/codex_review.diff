+      state: "unmapped",
+      text: `${toolContext.label} progress unavailable | ${journeyText}`,
+    };
+  }
+
+  return {
+    state: "active",
+    text: `${formatProgressRecord(toolContext.label, currentMetric)} | ${journeyText}`,
+  };
+}
