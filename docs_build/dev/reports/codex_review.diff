-  const scaleX = elements.canvas.width / Math.max(1, rect.width);
-  const scaleY = elements.canvas.height / Math.max(1, rect.height);
-  return {
-    x: (event.clientX - rect.left) * scaleX,
-    y: (event.clientY - rect.top) * scaleY,
-  };
