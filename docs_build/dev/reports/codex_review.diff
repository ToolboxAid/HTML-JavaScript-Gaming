+  }
+
+  function throttled(...args) {
+    const now = Date.now();
+    pendingArgs = args;
+    pendingContext = this;
+    const remaining = delay - (now - lastRun);
+
+    if (remaining <= 0 || remaining > delay) {
+      if (timeoutId !== null) {
+        clearTimeout(timeoutId);
+      }
+      invoke(now);
+      return;
+    }
+
+    if (timeoutId === null) {
+      timeoutId = setTimeout(() => invoke(Date.now()), remaining);
+    }
+  }
+
+  throttled.cancel = () => {
+    if (timeoutId !== null) {
+      clearTimeout(timeoutId);
+      timeoutId = null;
+    }
+    pendingArgs = null;
+    pendingContext = null;
+  };
+
+  return throttled;
+}
