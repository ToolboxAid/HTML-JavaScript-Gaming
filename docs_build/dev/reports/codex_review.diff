+-+  if (!address || typeof address === "string") {
+-+    throw new Error("Fake storage server did not start.");
+-+  }
+-+  return {
+-+    baseUrl: `http://127.0.0.1:${address.port}`,
+-+    bucket,
+-+    objects,
+-+    requests,
+-+    close: () => new Promise((resolve, reject) => server.close((error) => error ? reject(error) : resolve())),
