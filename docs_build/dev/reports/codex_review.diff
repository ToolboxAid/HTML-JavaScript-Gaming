-function previewImageUrl(visual = {}) {
-  const path = normalizeText(visual.previewPath);
-  if (!path) {
-    return "";
-  }
-  if (/^(https?:|data:|blob:|\/)/i.test(path)) {
-    return path;
-  }
-  return `/api/storage/project-assets/read?key=${encodeURIComponent(path)}`;
