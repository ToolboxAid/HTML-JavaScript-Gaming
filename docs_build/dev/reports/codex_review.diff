++function encodeBase32(value, length) {
++  let remaining = BigInt(value);
++  let encoded = "";
++  for (let index = 0; index < length; index += 1) {
++    encoded = ULID_ALPHABET[Number(remaining % 32n)] + encoded;
++    remaining /= 32n;
++  }
++  return encoded;
