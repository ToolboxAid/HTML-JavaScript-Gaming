+  }
+}
+
+function parseDatabaseUrl() {
+  const databaseUrl = new URL(envValue("GAMEFOUNDRY_SUPABASE_DATABASE_URL"));
+  if (!["postgres:", "postgresql:"].includes(databaseUrl.protocol)) {
