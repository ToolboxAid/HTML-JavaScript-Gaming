+-+          message: `Storage read failed with HTTP ${response.status}.`,
+-+          ok: false,
+-+        };
+-+      }
+-+      return {
+-+        bytes: Buffer.from(await response.arrayBuffer()),
+-+        contentType: response.headers.get("content-type") || "",
