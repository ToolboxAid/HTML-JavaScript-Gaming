{
  "$schema": "../../../tools/schemas/tools/replay-visualizer.schema.json",
  "tool": "replay-visualizer",
  "version": "1",
  "config": {
    "events": [
      {
        "id": "boot-0708",
        "timeMs": 0,
        "type": "boot",
        "label": "Replay Runtime Boot",
        "payload": {
          "scene": "replay-system"
        }
      },
      {
        "id": "record-start",
        "timeMs": 120,
        "type": "record",
        "label": "Start Recording",
        "payload": {
          "actor": "runner",
          "x": 120
        }
      },
      {
        "id": "record-stop",
        "timeMs": 620,
        "type": "record",
        "label": "Stop Recording",
        "payload": {
          "frames": 30,
          "x": 760
        }
      },
      {
        "id": "playback-start",
        "timeMs": 700,
        "type": "playback",
        "label": "Start Playback",
        "payload": {
          "mode": "deterministic"
        }
      },
      {
        "id": "playback-end",
        "timeMs": 1120,
        "type": "playback",
        "label": "Playback Complete",
        "payload": {
          "result": "match"
        }
      }
    ]
  }
}
