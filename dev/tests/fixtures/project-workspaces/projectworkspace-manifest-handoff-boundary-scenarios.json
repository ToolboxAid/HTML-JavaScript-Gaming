{
  "validHandoffs": [
    {
      "name": "tool consumes declared manifest fields only",
      "handoff": {
        "projectWorkspace": {
          "activeProjectId": "project.alpha",
          "activeToolId": "preview-generator-v2",
          "activeToolStateId": "tool-state.preview.alpha",
          "flowState": "opening"
        },
        "manifest": {
          "manifestId": "manifest.project.alpha",
          "ownerId": "user.owner",
          "projectId": "project.alpha",
          "projectType": "game",
          "sourceToolStates": [
            {
              "toolStateId": "tool-state.preview.alpha",
              "toolType": "preview-generator-v2",
              "version": 1
            }
          ],
          "sourceAssets": [],
          "visibility": "project",
          "version": 1,
          "status": "active",
          "exportFormat": "game-manifest-json"
        },
        "declaredManifestFields": [
          "manifestId",
          "projectId",
          "projectType",
          "sourceToolStates",
          "sourceAssets",
          "visibility",
          "version",
          "status",
          "exportFormat"
        ],
        "downstreamUseFields": [
          "manifestId",
          "projectId",
          "sourceToolStates"
        ]
      }
    }
  ],
  "invalidHandoffs": [
    {
