        "manifest": {
          "manifestId": "manifest.project.alpha",
          "ownerId": "user.owner",
          "projectId": "project.alpha",
          "projectType": "game",
          "sourceToolStates": [],
          "sourceAssets": [],
          "visibility": "project",
          "version": 1,
          "status": "active",
          "exportFormat": "game-manifest-json"
        },
        "declaredManifestFields": [
          "manifestId",
          "projectId"
        ],
        "downstreamUseFields": [
