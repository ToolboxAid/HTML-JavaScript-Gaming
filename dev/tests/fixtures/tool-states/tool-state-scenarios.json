  "accessChecks": [
    {
      "name": "private tool state owner can view",
      "actorId": "user.owner",
      "projectRole": "owner",
      "permission": "view",
      "toolState": {
        "toolStateId": "tool-state.private",
        "toolType": "palette-manager-v2",
        "ownerId": "user.owner",
        "projectId": "project.private",
        "visibility": "private",
        "version": 1,
        "status": "active"
      },
      "project": {
        "id": "project.private",
        "ownerId": "user.owner",
        "state": "active",
        "visibility": "private"
      },
      "expected": true
    },
    {
      "name": "private tool state ungranted user cannot view",
      "actorId": "user.other",
      "projectRole": "viewer",
      "permission": "view",
      "toolState": {
        "toolStateId": "tool-state.private",
        "toolType": "palette-manager-v2",
        "ownerId": "user.owner",
        "projectId": "project.private",
        "visibility": "private",
        "version": 1,
        "status": "active"
      },
      "project": {
        "id": "project.private",
        "ownerId": "user.owner",
        "state": "active",
        "visibility": "private"
      },
      "expected": false
    },
    {
      "name": "project-visible tool state granted collaborator can edit",
      "actorId": "user.collaborator",
      "projectRole": "collaborator",
      "permission": "edit",
      "grantedProjectIds": ["project.active"],
      "grantedScopes": ["project"],
      "toolState": {
        "toolStateId": "tool-state.project",
        "toolType": "palette-manager-v2",
        "ownerId": "user.owner",
        "projectId": "project.active",
        "visibility": "project",
        "version": 1,
        "status": "active"
      },
      "project": {
        "id": "project.active",
        "ownerId": "user.owner",
        "state": "active",
        "visibility": "project"
      },
      "expected": true
    },
    {
      "name": "viewer cannot edit tool state",
      "actorId": "user.viewer",
      "projectRole": "viewer",
      "permission": "edit",
      "grantedProjectIds": ["project.active"],
      "grantedScopes": ["project"],
      "toolState": {
        "toolStateId": "tool-state.project",
        "toolType": "palette-manager-v2",
        "ownerId": "user.owner",
        "projectId": "project.active",
        "visibility": "project",
        "version": 1,
        "status": "active"
      },
      "project": {
        "id": "project.active",
        "ownerId": "user.owner",
        "state": "active",
        "visibility": "project"
      },
      "expected": false
    },
    {
      "name": "archived tool state cannot be edited by default",
      "actorId": "user.owner",
      "projectRole": "owner",
      "permission": "edit",
      "toolState": {
        "toolStateId": "tool-state.archived",
        "toolType": "palette-manager-v2",
        "ownerId": "user.owner",
        "projectId": "project.active",
        "visibility": "private",
        "version": 2,
        "status": "archived"
      },
      "project": {
        "id": "project.active",
        "ownerId": "user.owner",
        "state": "active",
        "visibility": "private"
      },
      "expected": false
    },
    {
      "name": "archived tool state can be edited when policy allows",
      "actorId": "user.owner",
      "projectRole": "owner",
      "permission": "edit",
      "policy": {
        "allowArchivedToolStateEdit": true
      },
      "toolState": {
        "toolStateId": "tool-state.archived",
        "toolType": "palette-manager-v2",
        "ownerId": "user.owner",
        "projectId": "project.active",
        "visibility": "private",
        "version": 2,
        "status": "archived"
      },
      "project": {
        "id": "project.active",
        "ownerId": "user.owner",
        "state": "active",
        "visibility": "private"
      },
      "expected": true
    }
