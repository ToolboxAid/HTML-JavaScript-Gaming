    {
      "name": "payment state leakage",
      "overrides": {
        "paymentState": "authorized"
      },
      "expectedErrors": ["MARKETPLACE_TRANSACTION_BOUNDARY_FIELD_NOT_ALLOWED"]
    },
    {
      "name": "provider implementation leakage",
      "overrides": {
        "providerResponse": {}
      },
      "expectedErrors": ["MARKETPLACE_TRANSACTION_BOUNDARY_FIELD_NOT_ALLOWED"]
    },
    {
      "name": "runtime state leakage",
      "overrides": {
        "workspaceState": {}
      },
      "expectedErrors": ["MARKETPLACE_TRANSACTION_BOUNDARY_FIELD_NOT_ALLOWED"]
    }
  ]
