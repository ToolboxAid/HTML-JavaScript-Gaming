  "invalidMarketplaceTransactionBoundaries": [
    {
      "name": "missing owner",
      "overrides": {
        "ownerId": ""
      },
      "expectedErrors": ["MARKETPLACE_TRANSACTION_BOUNDARY_OWNER_REQUIRED"]
    },
    {
      "name": "missing marketplace listing",
      "removeFields": ["marketplaceListing"],
      "expectedErrors": ["MARKETPLACE_TRANSACTION_BOUNDARY_LISTING_REQUIRED"]
