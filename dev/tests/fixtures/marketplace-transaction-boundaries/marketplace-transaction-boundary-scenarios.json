    {
      "name": "invalid boundary status",
      "overrides": {
        "boundaryStatus": "settled"
      },
      "expectedErrors": ["MARKETPLACE_TRANSACTION_BOUNDARY_STATUS_INVALID"]
    },
    {
      "name": "missing created at",
      "overrides": {
        "createdAt": ""
      },
      "expectedErrors": ["MARKETPLACE_TRANSACTION_BOUNDARY_CREATED_AT_REQUIRED"]
