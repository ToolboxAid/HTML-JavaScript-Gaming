+-+  const render = normalizeObjectRender(input);
+-+  const details = objectDetailsFromSource(input, render);
+-+  return {
+-+    behavior: normalizeText(input.behavior),
+-+    capabilities: parseObjectCapabilities(input.traits || input.capabilities),
