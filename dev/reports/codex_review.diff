+    getSnapshot,
+    getTables: () => cloneTables(OBJECTS_TOOL_TABLES, lastTables),
+    listCachedObjects,
+    listObjects,
+    replaceObjects,
+    requiresAuthenticatedWrites: true,
+    resetObjects,
+    usesDatabasePersistence: true,
