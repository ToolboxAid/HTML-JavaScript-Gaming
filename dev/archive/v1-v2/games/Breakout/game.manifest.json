{
  "$schema": "tools/schemas/game.manifest.schema.json",
  "schema": "html-js-gaming.game-manifest",
  "version": 1,
  "game": {
    "id": "Breakout",
    "name": "Breakout",
    "folder": "Breakout"
  },
  "launch": {
    "directPath": "/old_old_games/Breakout/index.html"
  },
  "tools": {
    "palette-manager-v2": {
      "$schema": "tools/schemas/tools/palette-manager-v2.schema.json",
      "schema": "html-js-gaming.palette",
      "version": 1,
      "name": "Breakout Classic Palette",
      "source": "manifest",
      "swatches": [
        {
          "symbol": "!",
          "hex": "#000000",
          "name": "Background"
        },
        {
          "symbol": "#",
          "hex": "#F8F8F2",
          "name": "Wall/Paddle/Ball"
        },
        {
          "symbol": "$",
          "hex": "#FF595E",
          "name": "Brick Row 1"
        },
        {
          "symbol": "%",
          "hex": "#FF924C",
          "name": "Brick Row 2"
        },
        {
          "symbol": "&",
          "hex": "#FFCA3A",
          "name": "Brick Row 3"
        },
        {
          "symbol": "(",
          "hex": "#8AC926",
          "name": "Brick Row 4"
        },
        {
          "symbol": ")",
          "hex": "#1982C4",
          "name": "Brick Row 5"
        },
        {
          "symbol": "*",
          "hex": "#6A4C93",
          "name": "Brick Row 6"
        },
        {
          "symbol": "+",
          "hex": "#04040A",
          "name": "HUD Text"
        },
        {
          "symbol": ",",
          "hex": "#A0A0A0",
          "name": "HUD Muted"
        }
      ]
    },
    "asset-manager-v2": {
      "$schema": "tools/schemas/tools/asset-manager-v2.schema.json",
      "schema": "html-js-gaming.asset-manager-v2",
      "version": 1,
      "name": "Breakout Asset Manager V2 Registry",
      "source": "manifest",
      "assets": {
        "assets.image.preview.preview": {
          "path": "assets/images/preview.svg",
          "type": "image",
          "kind": "svg",
          "role": "preview",
          "source": "manifest"
        }
      }
    },
    "input-mapping-v2": {
      "$schema": "tools/schemas/tools/input-mapping-v2.schema.json",
      "toolId": "input-mapping-v2",
      "version": 1,
      "engineInputModel": "src/engine/input/InputMap",
      "actions": [
        {
          "action": "moveLeft",
          "label": "Move Left",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "ArrowLeft:KeyboardHold",
              "label": "Keyboard ArrowLeft Hold",
              "engine": "KeyboardState"
            },
            {
              "source": "keyboard",
              "binding": "KeyA:KeyboardHold",
              "label": "Keyboard KeyA Hold",
              "engine": "KeyboardState"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Button14:GameControllerDPad",
              "label": "Game Controller DPad Left DPad",
              "engine": "GamepadInputAdapter"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Axis0-:GameControllerStick",
              "label": "Game Controller Axis 0- Stick",
              "engine": "GamepadInputAdapter"
            }
          ]
        },
        {
          "action": "moveRight",
          "label": "Move Right",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "ArrowRight:KeyboardHold",
              "label": "Keyboard ArrowRight Hold",
              "engine": "KeyboardState"
            },
            {
              "source": "keyboard",
              "binding": "KeyD:KeyboardHold",
              "label": "Keyboard KeyD Hold",
              "engine": "KeyboardState"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Button15:GameControllerDPad",
              "label": "Game Controller DPad Right DPad",
              "engine": "GamepadInputAdapter"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Axis0+:GameControllerStick",
              "label": "Game Controller Axis 0+ Stick",
              "engine": "GamepadInputAdapter"
            }
          ]
        },
        {
          "action": "serve",
          "label": "Serve",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "Space",
              "label": "Keyboard Space Press",
              "engine": "KeyboardState"
            },
            {
              "source": "keyboard",
              "binding": "Enter",
              "label": "Keyboard Enter Press",
              "engine": "KeyboardState"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Button0:GameControllerButtonPress",
              "label": "Game Controller Button 0 Btn Press",
              "engine": "GamepadInputAdapter"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Button9:GameControllerButtonPress",
              "label": "Game Controller Button 9 Btn Press",
              "engine": "GamepadInputAdapter"
            }
          ]
        },
        {
          "action": "pause",
          "label": "Pause",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "KeyP",
              "label": "Keyboard KeyP Press",
              "engine": "KeyboardState"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Button9:GameControllerButtonPress",
              "label": "Game Controller Button 9 Btn Press",
              "engine": "GamepadInputAdapter"
            }
          ]
        },
        {
          "action": "exit",
          "label": "Exit",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "KeyX",
              "label": "Keyboard KeyX Press",
              "engine": "KeyboardState"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Button1:GameControllerButtonPress",
              "label": "Game Controller Button 1 Btn Press",
              "engine": "GamepadInputAdapter"
            }
          ]
        }
      ]
    }
  }
}
