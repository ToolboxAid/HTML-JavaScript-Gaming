{
  "$schema": "tools/schemas/game.manifest.schema.json",
  "schema": "html-js-gaming.game-manifest",
  "version": 1,
  "game": {
    "id": "SpaceInvaders",
    "name": "Space Invaders",
    "folder": "SpaceInvaders"
  },
  "launch": {
    "directPath": "/games/SpaceInvaders/index.html"
  },
  "screen": {
    "width": 960,
    "height": 720
  },
  "tools": {
    "palette-manager-v2": {
      "$schema": "tools/schemas/tools/palette-manager-v2.schema.json",
      "schema": "html-js-gaming.palette",
      "version": 1,
      "name": "Space Invaders Classic Palette",
      "source": "manifest",
      "swatches": [
        {
          "symbol": "!",
          "hex": "#000000",
          "name": "Background"
        },
        {
          "symbol": "#",
          "hex": "#020702",
          "name": "Playfield Backdrop"
        },
        {
          "symbol": "$",
          "hex": "#66FF66",
          "name": "Alien Green"
        },
        {
          "symbol": "%",
          "hex": "#8DF58D",
          "name": "HUD Green"
        },
        {
          "symbol": "&",
          "hex": "#FFFFFF",
          "name": "White Ink"
        },
        {
          "symbol": "(",
          "hex": "#D0D0D0",
          "name": "Score Label"
        },
        {
          "symbol": ")",
          "hex": "#FBBF24",
          "name": "Score Accent"
        },
        {
          "symbol": "*",
          "hex": "#FF4D4D",
          "name": "UFO Red"
        },
        {
          "symbol": "+",
          "hex": "#FF6666",
          "name": "Bomb Red"
        },
        {
          "symbol": ",",
          "hex": "#FFD1D1",
          "name": "Explosion Tint"
        }
      ]
    },
    "asset-manager-v2": {
      "$schema": "tools/schemas/tools/asset-manager-v2.schema.json",
      "schema": "html-js-gaming.asset-manager-v2",
      "version": 1,
      "name": "Space Invaders Asset Manager V2 Registry",
      "source": "manifest",
      "assets": {
        "assets.image.preview.preview": {
          "path": "assets/images/preview.svg",
          "type": "image",
          "kind": "svg",
          "role": "preview",
          "source": "manifest"
        },
        "assets.audio.space-invaders.shoot": {
          "path": "assets/audio/effects/shoot.wav",
          "type": "audio",
          "kind": "wav",
          "role": "sound",
          "source": "manifest"
        },
        "assets.audio.space-invaders.invaderkilled": {
          "path": "assets/audio/effects/invaderkilled.wav",
          "type": "audio",
          "kind": "wav",
          "role": "sound",
          "source": "manifest"
        },
        "assets.audio.space-invaders.explosion": {
          "path": "assets/audio/effects/explosion.wav",
          "type": "audio",
          "kind": "wav",
          "role": "sound",
          "source": "manifest"
        },
        "assets.audio.space-invaders.fastinvader1": {
          "path": "assets/audio/effects/fastinvader1.wav",
          "type": "audio",
          "kind": "wav",
          "role": "sound",
          "source": "manifest"
        },
        "assets.audio.space-invaders.fastinvader2": {
          "path": "assets/audio/effects/fastinvader2.wav",
          "type": "audio",
          "kind": "wav",
          "role": "sound",
          "source": "manifest"
        },
        "assets.audio.space-invaders.fastinvader3": {
          "path": "assets/audio/effects/fastinvader3.wav",
          "type": "audio",
          "kind": "wav",
          "role": "sound",
          "source": "manifest"
        },
        "assets.audio.space-invaders.fastinvader4": {
          "path": "assets/audio/effects/fastinvader4.wav",
          "type": "audio",
          "kind": "wav",
          "role": "sound",
          "source": "manifest"
        },
        "assets.audio.space-invaders.ufo-lowpitch": {
          "path": "assets/audio/effects/ufo_lowpitch.wav",
          "type": "audio",
          "kind": "wav",
          "role": "loop",
          "source": "manifest"
        },
        "assets.audio.space-invaders.ufo-highpitch": {
          "path": "assets/audio/effects/ufo_highpitch.wav",
          "type": "audio",
          "kind": "wav",
          "role": "loop",
          "source": "manifest"
        }
      }
    },
    "input-mapping-v2": {
      "$schema": "tools/schemas/tools/input-mapping-v2.schema.json",
      "toolId": "input-mapping-v2",
      "version": 1,
      "engineInputModel": "src/engine/input/InputMap",
      "actions": [
        {
          "action": "moveLeft",
          "label": "Move Left",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "ArrowLeft:KeyboardHold",
              "label": "Keyboard ArrowLeft Hold",
              "engine": "KeyboardState"
            },
            {
              "source": "keyboard",
              "binding": "KeyA:KeyboardHold",
              "label": "Keyboard KeyA Hold",
              "engine": "KeyboardState"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Button14:GameControllerDPad",
              "label": "Game Controller DPad Left DPad",
              "engine": "GamepadInputAdapter"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Axis0-:GameControllerStick",
              "label": "Game Controller Axis 0- Stick",
              "engine": "GamepadInputAdapter"
            }
          ]
        },
        {
          "action": "moveRight",
          "label": "Move Right",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "ArrowRight:KeyboardHold",
              "label": "Keyboard ArrowRight Hold",
              "engine": "KeyboardState"
            },
            {
              "source": "keyboard",
              "binding": "KeyD:KeyboardHold",
              "label": "Keyboard KeyD Hold",
              "engine": "KeyboardState"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Button15:GameControllerDPad",
              "label": "Game Controller DPad Right DPad",
              "engine": "GamepadInputAdapter"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Axis0+:GameControllerStick",
              "label": "Game Controller Axis 0+ Stick",
              "engine": "GamepadInputAdapter"
            }
          ]
        },
        {
          "action": "fire",
          "label": "Fire",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "Space",
              "label": "Keyboard Space Press",
              "engine": "KeyboardState"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Button0:GameControllerButtonPress",
              "label": "Game Controller Button 0 Btn Press",
              "engine": "GamepadInputAdapter"
            }
          ]
        },
        {
          "action": "fireHeld",
          "label": "Fire Held",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "Space:KeyboardHold",
              "label": "Keyboard Space Hold",
              "engine": "KeyboardState"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Button0:GameControllerButtonHold",
              "label": "Game Controller Button 0 Btn Hold",
              "engine": "GamepadInputAdapter"
            }
          ]
        },
        {
          "action": "start",
          "label": "Start",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "Enter",
              "label": "Keyboard Enter Press",
              "engine": "KeyboardState"
            },
            {
              "source": "keyboard",
              "binding": "Space",
              "label": "Keyboard Space Press",
              "engine": "KeyboardState"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Button9:GameControllerButtonPress",
              "label": "Game Controller Button 9 Btn Press",
              "engine": "GamepadInputAdapter"
            }
          ]
        },
        {
          "action": "pause",
          "label": "Pause",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "KeyP",
              "label": "Keyboard KeyP Press",
              "engine": "KeyboardState"
            }
          ]
        },
        {
          "action": "menu",
          "label": "Menu",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "KeyX",
              "label": "Keyboard KeyX Press",
              "engine": "KeyboardState"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Button1:GameControllerButtonPress",
              "label": "Game Controller Button 1 Btn Press",
              "engine": "GamepadInputAdapter"
            }
          ]
        },
        {
          "action": "debug",
          "label": "Debug",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "KeyB",
              "label": "Keyboard KeyB Press",
              "engine": "KeyboardState"
            }
          ]
        },
        {
          "action": "selectOnePlayer",
          "label": "Select One Player",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "Digit1",
              "label": "Keyboard Digit1 Press",
              "engine": "KeyboardState"
            },
            {
              "source": "keyboard",
              "binding": "Numpad1",
              "label": "Keyboard Numpad1 Press",
              "engine": "KeyboardState"
            }
          ]
        },
        {
          "action": "selectTwoPlayer",
          "label": "Select Two Player",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "Digit2",
              "label": "Keyboard Digit2 Press",
              "engine": "KeyboardState"
            },
            {
              "source": "keyboard",
              "binding": "Numpad2",
              "label": "Keyboard Numpad2 Press",
              "engine": "KeyboardState"
            }
          ]
        },
        {
          "action": "initialsPrevious",
          "label": "Initials Previous",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "ArrowLeft",
              "label": "Keyboard ArrowLeft Press",
              "engine": "KeyboardState"
            }
          ]
        },
        {
          "action": "initialsNext",
          "label": "Initials Next",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "ArrowRight",
              "label": "Keyboard ArrowRight Press",
              "engine": "KeyboardState"
            }
          ]
        },
        {
          "action": "initialsUp",
          "label": "Initials Up",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "ArrowUp",
              "label": "Keyboard ArrowUp Press",
              "engine": "KeyboardState"
            }
          ]
        },
        {
          "action": "initialsDown",
          "label": "Initials Down",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "ArrowDown",
              "label": "Keyboard ArrowDown Press",
              "engine": "KeyboardState"
            }
          ]
        },
        {
          "action": "initialsConfirm",
          "label": "Initials Confirm",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "Enter",
              "label": "Keyboard Enter Press",
              "engine": "KeyboardState"
            }
          ]
        }
      ]
    }
  }
}
