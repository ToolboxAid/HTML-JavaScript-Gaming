          "inputs": [
            {
              "source": "keyboard",
              "binding": "ArrowUp",
              "label": "Keyboard ArrowUp Press",
              "engine": "KeyboardState"
            }
          ]
        },
        {
          "action": "initialsDown",
          "label": "Initials Down",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "ArrowDown",
              "label": "Keyboard ArrowDown Press",
              "engine": "KeyboardState"
