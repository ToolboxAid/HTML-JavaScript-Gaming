          ]
        },
        {
          "action": "initialsConfirm",
          "label": "Initials Confirm",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "Enter",
              "label": "Keyboard Enter Press",
              "engine": "KeyboardState"
            }
          ]
        }
      ]
    },
