{
  "schema": "html-js-gaming.game-manifest",
  "version": 1,
  "game": {
    "id": "SpaceInvaders",
    "name": "Space Invaders Next",
    "folder": "SpaceInvaders"
  },
  "launch": {
    "directPath": "/games/SpaceInvaders/index.html",
    "workspaceManagerPath": "/tools/Workspace%20Manager/index.html?gameId=SpaceInvaders&mount=game",
    "workspaceManagerOptional": true
  },
  "tools": {
    "primitive-skin-editor": {
      "skins": [],
      "schema": "html-js-gaming.tool.primitive-skin-editor",
      "version": 1,
      "name": "Primitive Skin Editor",
      "source": "manifest"
    },
    "asset-browser": {
      "assets": {
        "media": {
          "audio.space-invaders.shoot": {
            "path": "games/SpaceInvaders/assets/audio/effects/shoot.wav",
            "kind": "audio",
            "source": "workspace-manager"
          },
          "audio.space-invaders.invaderkilled": {
            "path": "games/SpaceInvaders/assets/audio/effects/invaderkilled.wav",
            "kind": "audio",
            "source": "workspace-manager"
          },
          "audio.space-invaders.explosion": {
            "path": "games/SpaceInvaders/assets/audio/effects/explosion.wav",
            "kind": "audio",
            "source": "workspace-manager"
          },
          "audio.space-invaders.fastinvader1": {
            "path": "games/SpaceInvaders/assets/audio/effects/fastinvader1.wav",
            "kind": "audio",
            "source": "workspace-manager"
          },
          "audio.space-invaders.fastinvader2": {
            "path": "games/SpaceInvaders/assets/audio/effects/fastinvader2.wav",
            "kind": "audio",
            "source": "workspace-manager"
          },
          "audio.space-invaders.fastinvader3": {
            "path": "games/SpaceInvaders/assets/audio/effects/fastinvader3.wav",
            "kind": "audio",
            "source": "workspace-manager"
          },
          "audio.space-invaders.fastinvader4": {
            "path": "games/SpaceInvaders/assets/audio/effects/fastinvader4.wav",
            "kind": "audio",
            "source": "workspace-manager"
          },
          "audio.space-invaders.ufo-lowpitch": {
            "path": "games/SpaceInvaders/assets/audio/effects/ufo_lowpitch.wav",
            "kind": "audio",
            "source": "workspace-manager"
          },
          "audio.space-invaders.ufo-highpitch": {
            "path": "games/SpaceInvaders/assets/audio/effects/ufo_highpitch.wav",
            "kind": "audio",
            "source": "workspace-manager"
          }
        }
      },
      "schema": "html-js-gaming.tool.asset-browser",
      "version": 1,
      "name": "Asset Browser",
      "source": "manifest"
    },
    "palette-browser": {
      "schema": "html-js-gaming.tool.palette-browser",
      "version": 1,
      "name": "Palette Browser",
      "source": "manifest",
      "palette": {
        "schema": "html-js-gaming.palette",
        "version": 1,
        "name": "Space Invaders Next Palette",
        "source": "manifest-and-runtime-color-scan",
        "swatches": [
          {
            "symbol": "0",
            "hex": "#000000",
            "name": "Color 1"
          },
          {
            "symbol": "1",
            "hex": "#020702",
            "name": "Color 2"
          },
          {
            "symbol": "2",
            "hex": "#66FF66",
            "name": "Color 3"
          },
          {
            "symbol": "3",
            "hex": "#8DF58D",
            "name": "Color 4"
          },
          {
            "symbol": "4",
            "hex": "#FFFFFF",
            "name": "Color 5"
          },
          {
            "symbol": "5",
            "hex": "#D0D0D0",
            "name": "Color 6"
          },
          {
            "symbol": "6",
            "hex": "#FBBF24",
            "name": "Color 7"
          },
          {
            "symbol": "7",
            "hex": "#FF4D4D",
            "name": "Color 8"
          },
          {
            "symbol": "8",
            "hex": "#FF6666",
            "name": "Color 9"
          },
          {
            "symbol": "9",
