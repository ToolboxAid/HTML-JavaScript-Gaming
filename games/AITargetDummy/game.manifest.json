{
  "schema": "html-js-gaming.game-manifest",
  "version": 1,
  "game": {
    "id": "AITargetDummy",
    "name": "AI Target Dummy",
    "folder": "AITargetDummy"
  },
  "launch": {
    "directPath": "/games/AITargetDummy/index.html",
    "workspaceManagerPath": "/tools/Workspace%20Manager/index.html?gameId=AITargetDummy&mount=game",
    "workspaceManagerOptional": true
  },
  "tools": {
    "asset-browser": {
      "assets": {
        "media": {
          "image.ai-target-dummy.preview": {
            "path": "games/AITargetDummy/assets/images/preview.svg",
            "kind": "image",
            "source": "workspace-manager"
          }
        }
      },
      "schema": "html-js-gaming.tool.asset-browser",
      "version": 1,
      "name": "Asset Browser",
      "source": "manifest"
    },
    "primitive-skin-editor": {
      "skins": [],
      "schema": "html-js-gaming.tool.primitive-skin-editor",
      "version": 1,
      "name": "Primitive Skin Editor",
      "source": "manifest"
    },
    "palette-browser": {
      "schema": "html-js-gaming.tool.palette-browser",
      "version": 1,
      "name": "Palette Browser",
      "source": "manifest",
      "palette": {
        "schema": "html-js-gaming.palette",
        "version": 1,
        "name": "AI Target Dummy Palette",
        "source": "manifest-and-runtime-color-scan",
