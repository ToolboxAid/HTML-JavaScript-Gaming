      "name": "Vector Asset Studio",
      "source": "manifest"
    },
    "asset-browser": {
      "assets": {
        "media": {
          "image.vector-arcade.backdrop-svg": {
            "path": "games/vector-arcade-sample/assets/data/parallax/template-backdrop.svg",
            "kind": "image",
            "source": "workspace-manager"
          }
        }
      },
      "schema": "html-js-gaming.tool.asset-browser",
      "version": 1,
      "name": "Asset Browser",
      "source": "manifest"
    },
    "preview-generator-tool": {
      "projectConfigs": [
        {
          "id": "games.vector.arcade.sample.config.sample.project",
          "data": {
            "sampleId": "vector-arcade-sample",
            "schema": "toolbox.sample/1",
            "visualContract": "vector-only",
            "runtimeEntry": "games/vector-arcade-sample/main.js#bootVectorArcadeSample"
          }
        }
      ],
      "runtimeConfigs": [
        {
          "id": "games.vector.arcade.sample.runtime.bootstrap.runtime",
          "data": {
            "modulePath": "games/vector-arcade-sample/main.js",
            "exportName": "bootVectorArcadeSample",
            "canvasId": "game",
            "requiredVectorIds": [
              "vector.template.player",
              "vector.template.obstacle.large",
              "vector.template.obstacle.small",
              "vector.template.ui.title",
              "vector.template.ui.hud"
            ]
          }
        }
      ],
      "schema": "html-js-gaming.tool.preview-generator-tool",
      "version": 1,
      "name": "Preview Generator Tool",
      "source": "manifest"
    },
    "palette-browser": {
      "schema": "html-js-gaming.tool.palette-browser",
      "version": 1,
      "name": "Palette Browser",
      "source": "manifest",
      "palette": {
        "schema": "html-js-gaming.palette",
