{
  "$schema": "tools/schemas/game.manifest.schema.json",
  "schema": "html-js-gaming.game-manifest",
  "version": 1,
  "game": {
    "id": "vector-arcade-sample",
    "name": "Vector Arcade Sample",
    "folder": "vector-arcade-sample"
  },
  "launch": {
    "directPath": "/games/vector-arcade-sample/index.html"
  },
  "tools": {
    "palette-manager-v2": {
      "$schema": "tools/schemas/tools/palette-manager-v2.schema.json",
      "schema": "html-js-gaming.palette",
      "version": 1,
      "name": "Vector Native Primary Palette",
      "source": "manifest",
      "swatches": [
        {
          "symbol": "!",
          "hex": "#05070D",
          "name": "Swatch 1"
        },
        {
          "symbol": "#",
          "hex": "#E8F0FF",
          "name": "Swatch 2"
        },
        {
          "symbol": "$",
          "hex": "#6FD3FF",
          "name": "Swatch 3"
        },
        {
          "symbol": "%",
          "hex": "#FFB347",
          "name": "Swatch 4"
        }
      ]
    },
    "asset-manager-v2": {
      "$schema": "tools/schemas/tools/asset-manager-v2.schema.json",
      "schema": "html-js-gaming.asset-manager-v2",
      "version": 1,
      "name": "Vector Arcade Sample Asset Manager V2 Registry",
      "source": "manifest",
      "assets": {
        "assets.image.preview.preview": {
          "path": "assets/images/preview.svg",
          "type": "image",
          "kind": "svg",
          "role": "preview",
          "source": "manifest"
        }
      }
    },
    "input-mapping-v2": {
      "$schema": "tools/schemas/tools/input-mapping-v2.schema.json",
      "toolId": "input-mapping-v2",
      "version": 1,
      "engineInputModel": "src/engine/input/InputMap",
      "actions": [
        {
          "action": "startOnePlayer",
          "label": "Start One Player",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "Digit1",
              "label": "Keyboard Digit1 Press",
              "engine": "KeyboardState"
            }
          ]
        },
        {
          "action": "startTwoPlayer",
          "label": "Start Two Player",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "Digit2",
              "label": "Keyboard Digit2 Press",
              "engine": "KeyboardState"
            }
          ]
        },
        {
          "action": "continue",
          "label": "Continue",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "Enter",
              "label": "Keyboard Enter Press",
              "engine": "KeyboardState"
            }
          ]
        },
        {
          "action": "rotateLeft",
          "label": "Rotate Left",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "ArrowLeft:KeyboardHold",
              "label": "Keyboard ArrowLeft Hold",
              "engine": "KeyboardState"
            }
          ]
        },
        {
          "action": "rotateRight",
          "label": "Rotate Right",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "ArrowRight:KeyboardHold",
              "label": "Keyboard ArrowRight Hold",
              "engine": "KeyboardState"
            }
          ]
        },
        {
          "action": "thrust",
          "label": "Thrust",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "ArrowUp:KeyboardHold",
              "label": "Keyboard ArrowUp Hold",
              "engine": "KeyboardState"
            }
          ]
        },
        {
          "action": "fire",
          "label": "Fire",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "Space",
              "label": "Keyboard Space Press",
              "engine": "KeyboardState"
            }
          ]
        },
        {
          "action": "pause",
          "label": "Pause",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "KeyP",
              "label": "Keyboard KeyP Press",
              "engine": "KeyboardState"
            }
          ]
        },
        {
          "action": "initialsPrevious",
          "label": "Initials Previous",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "ArrowLeft",
              "label": "Keyboard ArrowLeft Press",
              "engine": "KeyboardState"
            }
          ]
        },
        {
          "action": "initialsNext",
          "label": "Initials Next",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "ArrowRight",
              "label": "Keyboard ArrowRight Press",
              "engine": "KeyboardState"
            }
          ]
        },
        {
          "action": "initialsUp",
          "label": "Initials Up",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "ArrowUp",
              "label": "Keyboard ArrowUp Press",
              "engine": "KeyboardState"
            }
          ]
