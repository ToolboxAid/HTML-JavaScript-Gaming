          "data": {
            "id": "vector.template.ui.title",
            "type": "vector",
            "source": {
              "kind": "svg",
              "path": "games/vector-arcade-sample/assets/data/vectors/template-title.vector.json"
            },
            "geometry": {
              "viewBox": "0 0 220 48",
              "paths": [
                {
