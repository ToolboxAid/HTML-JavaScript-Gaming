{
  "schema": "html-js-gaming.game-manifest",
  "version": 1,
  "game": {
    "id": "vector-arcade-sample",
    "name": "Vector Arcade Sample",
    "folder": "vector-arcade-sample"
  },
  "launch": {
    "directPath": "/games/vector-arcade-sample/index.html",
    "workspaceManagerPath": "/tools/Workspace%20Manager/index.html?gameId=vector-arcade-sample&mount=game",
    "workspaceManagerOptional": true
  },
  "tools": {
    "primitive-skin-editor": {
      "skins": [],
      "schema": "html-js-gaming.tool.primitive-skin-editor",
      "version": 1,
      "name": "Primitive Skin Editor",
      "source": "manifest"
    },
    "sprite-editor": {
      "sprites": [
        {
          "id": "sprite.vector-arcade.player",
          "data": {
            "schema": "toolbox.sprite-project/1",
            "version": 1,
            "projectId": "vector-arcade-template-sprite",
            "name": "Vector Arcade Template Sprite",
            "frames": [
              {
                "id": "idle-0",
                "width": 16,
                "height": 16,
                "durationMs": 120,
                "pixels": []
              }
            ],
            "palette": [
              "#000000",
              "#ffffff",
              "#60a5fa",
              "#f59e0b"
            ]
          }
        }
      ],
      "schema": "html-js-gaming.tool.sprite-editor",
      "version": 1,
      "name": "Sprite Editor",
      "source": "manifest"
    },
    "tile-map-editor": {
      "maps": [
        {
          "id": "tilemap.vector-arcade.arena",
          "data": {
            "name": "Vector Arcade Sample Arena",
            "states": [
              "title",
              "start",
              "gameplay",
              "restart"
            ],
            "extensionPoints": [
              "spawn-patterns",
              "score-rules",
              "victory-conditions"
            ]
          }
        }
      ],
      "tilesets": [
        {
          "id": "tilemap.vector-arcade.ui",
          "data": {
            "name": "Template UI Tileset",
            "tileWidth": 8,
            "tileHeight": 8,
            "tiles": [
              "score-panel",
              "wave-panel",
              "status-panel"
            ]
          }
        }
      ],
      "schema": "html-js-gaming.tool.tile-map-editor",
      "version": 1,
      "name": "Tile Map Editor",
      "source": "manifest"
    },
    "parallax-editor": {
      "parallaxLevels": [
        {
          "id": "parallax.vector-arcade.backdrop",
          "data": {
            "name": "Sample Backdrop Layer",
            "role": "backdrop",
            "imageId": "image.template.backdrop"
          }
        }
      ],
      "schema": "html-js-gaming.tool.parallax-editor",
      "version": 1,
      "name": "Parallax Editor",
      "source": "manifest"
    },
    "vector-asset-studio": {
