{
  "schema": "html-js-gaming.game-manifest",
  "version": 1,
  "game": {
    "id": "SpaceDuel",
    "name": "Space Duel",
    "folder": "SpaceDuel"
  },
  "launch": {
    "directPath": "/games/SpaceDuel/index.html",
    "workspaceManagerPath": "/tools/Workspace%20Manager/index.html?gameId=SpaceDuel&mount=game",
    "workspaceManagerOptional": true
  },
  "tools": {
    "primitive-skin-editor": {
      "skins": [],
      "schema": "html-js-gaming.tool.primitive-skin-editor",
      "version": 1,
      "name": "Primitive Skin Editor",
      "source": "manifest"
    },
    "asset-browser": {
      "assets": {
        "media": {
          "audio.space-duel.thrust": {
            "path": "games/SpaceDuel/assets/audio/effects/thrust.wav",
            "kind": "audio",
            "source": "workspace-manager"
          },
          "audio.space-duel.fire": {
            "path": "games/SpaceDuel/assets/audio/effects/fire.wav",
            "kind": "audio",
            "source": "workspace-manager"
          },
          "audio.space-duel.explosion": {
            "path": "games/SpaceDuel/assets/audio/effects/explosion.wav",
            "kind": "audio",
            "source": "workspace-manager"
          },
          "audio.space-duel.player-death": {
            "path": "games/SpaceDuel/assets/audio/effects/player_death.wav",
            "kind": "audio",
            "source": "workspace-manager"
          },
          "audio.space-duel.enemy-split": {
            "path": "games/SpaceDuel/assets/audio/effects/enemy_split.wav",
            "kind": "audio",
            "source": "workspace-manager"
          },
          "audio.space-duel.bonus": {
            "path": "games/SpaceDuel/assets/audio/effects/bonus.wav",
            "kind": "audio",
            "source": "workspace-manager"
          },
          "audio.space-duel.start": {
            "path": "games/SpaceDuel/assets/audio/effects/start.wav",
            "kind": "audio",
            "source": "workspace-manager"
          },
          "audio.space-duel.game-over": {
            "path": "games/SpaceDuel/assets/audio/effects/game_over.wav",
            "kind": "audio",
            "source": "workspace-manager"
          }
        }
      },
      "schema": "html-js-gaming.tool.asset-browser",
      "version": 1,
      "name": "Asset Browser",
      "source": "manifest"
    },
    "palette-browser": {
      "schema": "html-js-gaming.tool.palette-browser",
      "version": 1,
      "name": "Palette Browser",
      "source": "manifest",
      "palette": {
        "schema": "html-js-gaming.palette",
        "version": 1,
        "name": "Space Duel Palette",
        "source": "manifest-and-runtime-color-scan",
        "swatches": [
          {
            "symbol": "0",
            "hex": "#020617",
            "name": "Color 1"
          },
          {
            "symbol": "1",
            "hex": "#E2E8F0",
            "name": "Color 2"
          },
          {
            "symbol": "2",
            "hex": "#8AA0BB",
            "name": "Color 3"
          },
          {
            "symbol": "3",
            "hex": "#334155",
            "name": "Color 4"
          },
          {
            "symbol": "4",
            "hex": "#93A5BC",
            "name": "Color 5"
          },
          {
            "symbol": "5",
            "hex": "#FFFFFF",
            "name": "Color 6"
          },
          {
            "symbol": "6",
            "hex": "#9AE6B4",
            "name": "Color 7"
          },
          {
            "symbol": "7",
            "hex": "#FCA5A5",
            "name": "Color 8"
          },
          {
            "symbol": "8",
            "hex": "#FECACA",
            "name": "Color 9"
          },
          {
            "symbol": "9",
