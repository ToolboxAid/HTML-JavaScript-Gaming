{
  "$schema": "tools/schemas/game.manifest.schema.json",
  "schema": "html-js-gaming.game-manifest",
  "version": 1,
  "game": {
    "id": "SpaceDuel",
    "name": "Space Duel",
    "folder": "SpaceDuel"
  },
  "launch": {
    "directPath": "/games/SpaceDuel/index.html"
  },
  "tools": {
    "palette-manager-v2": {
      "$schema": "tools/schemas/tools/palette-manager-v2.schema.json",
      "schema": "html-js-gaming.palette",
      "version": 1,
      "name": "Space Duel Classic Palette",
      "source": "manifest",
      "swatches": [
        {
          "symbol": "!",
          "hex": "#020617",
          "name": "Background"
        },
        {
          "symbol": "#",
          "hex": "#E2E8F0",
          "name": "Primary Ink"
        },
        {
          "symbol": "$",
          "hex": "#8AA0BB",
          "name": "Border"
        },
        {
          "symbol": "%",
          "hex": "#334155",
          "name": "Inner Border"
        },
        {
          "symbol": "&",
          "hex": "#93A5BC",
          "name": "Muted Text"
        },
        {
          "symbol": "(",
          "hex": "#FFFFFF",
          "name": "Player 1"
        },
        {
          "symbol": ")",
          "hex": "#9AE6B4",
          "name": "Player 2"
        },
        {
          "symbol": "*",
          "hex": "#FCA5A5",
          "name": "Hazard"
        },
        {
          "symbol": "+",
          "hex": "#FECACA",
          "name": "Hazard Inner"
        },
        {
          "symbol": ",",
          "hex": "#F59E0B",
          "name": "Bonus Ring"
        },
        {
          "symbol": "-",
          "hex": "#FDE68A",
          "name": "Bonus Core"
        },
        {
          "symbol": ".",
          "hex": "#F8FAFC",
          "name": "Projectile"
        }
      ]
    },
    "asset-manager-v2": {
      "$schema": "tools/schemas/tools/asset-manager-v2.schema.json",
      "schema": "html-js-gaming.asset-manager-v2",
      "version": 1,
      "name": "Space Duel Asset Manager V2 Registry",
      "source": "manifest",
      "assets": {
        "assets.image.preview.preview": {
          "path": "assets/images/preview.svg",
          "type": "image",
          "kind": "svg",
          "role": "preview",
          "source": "manifest"
        }
      }
    },
    "input-mapping-v2": {
      "$schema": "tools/schemas/tools/input-mapping-v2.schema.json",
      "toolId": "input-mapping-v2",
      "version": 1,
      "engineInputModel": "src/engine/input/InputMap",
      "actions": [
        {
          "action": "startOnePlayer",
          "label": "Start One Player",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "Digit1",
              "label": "Keyboard Digit1 Press",
              "engine": "KeyboardState"
            },
            {
              "source": "keyboard",
              "binding": "Numpad1",
              "label": "Keyboard Numpad1 Press",
              "engine": "KeyboardState"
            },
            {
              "source": "keyboard",
              "binding": "Enter",
              "label": "Keyboard Enter Press",
              "engine": "KeyboardState"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Button0:GameControllerButtonPress",
              "label": "Game Controller Button 0 Btn Press",
              "engine": "GamepadInputAdapter"
            }
          ]
        },
        {
          "action": "startTwoPlayer",
          "label": "Start Two Player",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "Digit2",
              "label": "Keyboard Digit2 Press",
              "engine": "KeyboardState"
            },
            {
              "source": "keyboard",
              "binding": "Numpad2",
              "label": "Keyboard Numpad2 Press",
              "engine": "KeyboardState"
            },
            {
              "source": "gamepad",
              "binding": "Pad1:Button0:GameControllerButtonPress",
              "label": "Game Controller Button 0 Btn Press",
              "engine": "GamepadInputAdapter"
            }
          ]
        },
        {
          "action": "pause",
          "label": "Pause",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "KeyP",
              "label": "Keyboard KeyP Press",
              "engine": "KeyboardState"
            },
            {
              "source": "keyboard",
              "binding": "Escape",
              "label": "Keyboard Escape Press",
              "engine": "KeyboardState"
            },
            {
              "source": "gamepad",
              "binding": "Pad0:Button9:GameControllerButtonPress",
              "label": "Game Controller Button 9 Btn Press",
              "engine": "GamepadInputAdapter"
            },
            {
              "source": "gamepad",
              "binding": "Pad1:Button9:GameControllerButtonPress",
              "label": "Game Controller Button 9 Btn Press",
              "engine": "GamepadInputAdapter"
            }
          ]
        },
