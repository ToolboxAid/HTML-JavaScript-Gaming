{
  "$schema": "tools/schemas/game.manifest.schema.json",
  "schema": "html-js-gaming.game-manifest",
  "version": 1,
  "game": {
    "id": "SpaceDuel",
    "name": "Space Duel",
    "folder": "SpaceDuel"
  },
  "launch": {
    "directPath": "/games/SpaceDuel/index.html"
  },
  "screen": {
    "width": 960,
    "height": 720
  },
