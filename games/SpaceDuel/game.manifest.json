{
  "$schema": "tools/schemas/game.manifest.schema.json",
  "schema": "html-js-gaming.game-manifest",
  "version": 1,
  "game": {
    "id": "SpaceDuel",
    "name": "Space Duel",
    "folder": "SpaceDuel"
  },
  "launch": {
    "directPath": "/games/SpaceDuel/index.html"
  },
  "tools": {
    "palette-manager-v2": {
      "$schema": "tools/schemas/tools/palette-manager-v2.schema.json",
      "schema": "html-js-gaming.palette",
      "version": 1,
      "name": "Space Duel Classic Palette",
      "source": "manifest",
      "swatches": [
        {
          "symbol": "!",
          "hex": "#020617",
          "name": "Background"
        },
        {
          "symbol": "#",
          "hex": "#E2E8F0",
          "name": "Primary Ink"
        },
        {
          "symbol": "$",
          "hex": "#8AA0BB",
          "name": "Border"
        },
        {
          "symbol": "%",
          "hex": "#334155",
          "name": "Inner Border"
        },
        {
          "symbol": "&",
          "hex": "#93A5BC",
          "name": "Muted Text"
        },
        {
          "symbol": "(",
          "hex": "#FFFFFF",
          "name": "Player 1"
        },
        {
          "symbol": ")",
          "hex": "#9AE6B4",
          "name": "Player 2"
        },
        {
          "symbol": "*",
          "hex": "#FCA5A5",
          "name": "Hazard"
        },
        {
          "symbol": "+",
          "hex": "#FECACA",
          "name": "Hazard Inner"
        },
        {
          "symbol": ",",
          "hex": "#F59E0B",
          "name": "Bonus Ring"
        },
        {
          "symbol": "-",
          "hex": "#FDE68A",
          "name": "Bonus Core"
        },
        {
          "symbol": ".",
          "hex": "#F8FAFC",
          "name": "Projectile"
        }
      ]
    },
    "asset-manager-v2": {
      "$schema": "tools/schemas/tools/asset-manager-v2.schema.json",
      "schema": "html-js-gaming.asset-manager-v2",
      "version": 1,
      "name": "Space Duel Asset Manager V2 Registry",
      "source": "manifest",
      "assets": {
        "assets.image.preview.preview": {
          "path": "assets/images/preview.svg",
          "type": "image",
          "kind": "svg",
          "role": "preview",
          "source": "manifest"
        }
      }
    },
    "input-mapping-v2": {
      "$schema": "tools/schemas/tools/input-mapping-v2.schema.json",
      "toolId": "input-mapping-v2",
      "version": 1,
      "engineInputModel": "src/engine/input/InputMap",
      "actions": [
        {
          "action": "cancel",
          "label": "Cancel",
          "inputs": []
        },
        {
          "action": "confirm",
          "label": "Confirm",
          "inputs": []
        },
        {
          "action": "fire",
          "label": "Fire",
          "inputs": []
        },
        {
          "action": "interact",
          "label": "Interact",
          "inputs": []
        },
        {
          "action": "jump",
          "label": "Jump",
          "inputs": []
        },
        {
          "action": "menu",
          "label": "Menu",
          "inputs": []
        },
        {
          "action": "moveDown",
          "label": "Move Down",
          "inputs": []
        },
        {
          "action": "moveLeft",
          "label": "Move Left",
          "inputs": []
