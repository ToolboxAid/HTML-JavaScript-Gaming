{
  "$schema": "tools/schemas/game.manifest.schema.json",
  "schema": "html-js-gaming.game-manifest",
  "version": 1,
  "game": {
    "id": "Breakout",
    "name": "Breakout",
    "folder": "Breakout"
  },
  "launch": {
    "directPath": "/games/Breakout/index.html"
  },
  "tools": {
    "palette-manager-v2": {
      "$schema": "tools/schemas/tools/palette-manager-v2.schema.json",
      "schema": "html-js-gaming.palette",
      "version": 1,
      "name": "Breakout Classic Palette",
      "source": "manifest",
      "swatches": [
        {
          "symbol": "!",
          "hex": "#000000",
          "name": "Background"
        },
        {
          "symbol": "#",
          "hex": "#F8F8F2",
          "name": "Wall/Paddle/Ball"
        },
        {
          "symbol": "$",
          "hex": "#FF595E",
          "name": "Brick Row 1"
        },
        {
          "symbol": "%",
          "hex": "#FF924C",
          "name": "Brick Row 2"
        },
        {
          "symbol": "&",
          "hex": "#FFCA3A",
          "name": "Brick Row 3"
        },
        {
          "symbol": "(",
          "hex": "#8AC926",
          "name": "Brick Row 4"
        },
        {
          "symbol": ")",
          "hex": "#1982C4",
          "name": "Brick Row 5"
        },
        {
          "symbol": "*",
          "hex": "#6A4C93",
          "name": "Brick Row 6"
        },
        {
          "symbol": "+",
          "hex": "#04040A",
          "name": "HUD Text"
        },
        {
          "symbol": ",",
          "hex": "#A0A0A0",
          "name": "HUD Muted"
        }
      ]
    },
    "asset-manager-v2": {
      "$schema": "tools/schemas/tools/asset-manager-v2.schema.json",
      "schema": "html-js-gaming.asset-manager-v2",
      "version": 1,
      "name": "Breakout Asset Manager V2 Registry",
      "source": "manifest",
      "assets": {
        "assets.image.preview.preview": {
          "path": "assets/images/preview.svg",
          "type": "image",
          "kind": "svg",
          "role": "preview",
          "source": "manifest"
        }
      }
    },
    "input-mapping-v2": {
      "$schema": "tools/schemas/tools/input-mapping-v2.schema.json",
      "toolId": "input-mapping-v2",
      "version": 1,
      "engineInputModel": "src/engine/input/InputMap",
      "actions": [
        {
          "action": "cancel",
          "label": "Cancel",
          "inputs": []
        },
        {
          "action": "confirm",
          "label": "Confirm",
          "inputs": []
        },
        {
          "action": "fire",
          "label": "Fire",
          "inputs": []
        },
        {
          "action": "interact",
          "label": "Interact",
          "inputs": []
        },
        {
          "action": "jump",
          "label": "Jump",
          "inputs": []
        },
        {
          "action": "menu",
          "label": "Menu",
          "inputs": []
        },
        {
          "action": "moveDown",
          "label": "Move Down",
          "inputs": []
        },
        {
          "action": "moveLeft",
          "label": "Move Left",
          "inputs": []
        },
        {
          "action": "moveRight",
          "label": "Move Right",
          "inputs": []
        },
        {
          "action": "moveUp",
          "label": "Move Up",
          "inputs": []
        },
        {
          "action": "pause",
          "label": "Pause",
          "inputs": []
        },
        {
          "action": "primaryAction",
          "label": "Primary Action",
          "inputs": []
        },
        {
          "action": "rotateLeft",
          "label": "Rotate Left",
          "inputs": []
        },
        {
          "action": "rotateRight",
          "label": "Rotate Right",
          "inputs": []
        },
        {
          "action": "secondaryAction",
          "label": "Secondary Action",
          "inputs": []
        },
        {
          "action": "select",
          "label": "Select",
          "inputs": []
        },
        {
          "action": "start",
          "label": "Start",
          "inputs": []
        },
        {
          "action": "thrust",
          "label": "Thrust",
          "inputs": []
        }
      ]
    }
  }
}
