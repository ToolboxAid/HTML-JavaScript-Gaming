{
  "$schema": "tools/schemas/game.manifest.schema.json",
  "schema": "html-js-gaming.game-manifest",
  "version": 1,
  "game": {
    "id": "_template",
    "name": "Game Template",
    "folder": "_template"
  },
  "launch": {
    "directPath": "/games/_template/index.html",
    "workspaceManagerPath": "/tools/workspace-manager-v2/index.html?gameId=_template",
    "workspaceManagerOptional": true
  },
  "tools": {
    "palette-manager-v2": {
      "$schema": "tools/schemas/tools/palette-manager-v2.schema.json",
      "schema": "html-js-gaming.palette",
      "id": "palette._template.default",
      "version": 1,
      "name": "Game Template Palette",
      "source": "manifest",
      "swatches": [
        {
          "symbol": "0",
          "hex": "#F8FAFC",
          "name": "Template Light"
        },
        {
          "symbol": "1",
          "hex": "#0F172A",
          "name": "Template Dark"
        }
      ]
    },
    "asset-manager-v2": {
      "$schema": "tools/schemas/tools/asset-manager-v2.schema.json",
      "schema": "html-js-gaming.asset-manager-v2",
      "version": 1,
      "id": "asset-manager-v2._template.registry",
      "name": "Game Template Asset Manager V2 Registry",
      "source": "manifest",
      "assets": {}
    },
    "input-mapping-v2": {
      "$schema": "tools/schemas/tools/input-mapping-v2.schema.json",
      "toolId": "input-mapping-v2",
      "version": 1,
      "engineInputModel": "src/engine/input/InputMap",
      "actions": [
        {
          "action": "cancel",
          "label": "Cancel",
          "inputs": []
        },
        {
          "action": "confirm",
          "label": "Confirm",
          "inputs": []
        },
        {
          "action": "fire",
          "label": "Fire",
          "inputs": []
        },
        {
          "action": "interact",
          "label": "Interact",
          "inputs": []
        },
        {
          "action": "jump",
          "label": "Jump",
          "inputs": []
        },
        {
          "action": "menu",
          "label": "Menu",
          "inputs": []
        },
        {
          "action": "moveDown",
          "label": "Move Down",
          "inputs": []
        },
        {
          "action": "moveLeft",
          "label": "Move Left",
          "inputs": []
        },
        {
          "action": "moveRight",
          "label": "Move Right",
          "inputs": []
        },
        {
          "action": "moveUp",
          "label": "Move Up",
          "inputs": []
        },
        {
          "action": "pause",
          "label": "Pause",
          "inputs": []
        },
        {
          "action": "primaryAction",
          "label": "Primary Action",
          "inputs": []
        },
        {
          "action": "rotateLeft",
          "label": "Rotate Left",
          "inputs": []
        },
        {
          "action": "rotateRight",
          "label": "Rotate Right",
          "inputs": []
        },
        {
          "action": "secondaryAction",
          "label": "Secondary Action",
          "inputs": []
        },
        {
          "action": "select",
          "label": "Select",
          "inputs": []
        },
        {
          "action": "start",
          "label": "Start",
          "inputs": []
        },
        {
          "action": "thrust",
          "label": "Thrust",
          "inputs": []
        }
      ]
    }
  }
}
