      "$schema": "tools/schemas/tools/palette-manager-v2.schema.json",
      "schema": "html-js-gaming.palette",
      "version": 1,
      "name": "Solar System Classic Palette",
      "source": "manifest",
      "swatches": [
        {
          "symbol": "!",
          "hex": "#030712",
          "name": "Space Background"
        },
        {
          "symbol": "#",
          "hex": "#DBEAFE",
          "name": "Frame and Text"
        },
        {
          "symbol": "$",
          "hex": "#334155",
          "name": "Orbits"
        },
        {
          "symbol": "%",
          "hex": "#FBBF24",
          "name": "Sun"
        },
        {
          "symbol": "&",
          "hex": "#9CA3AF",
          "name": "Mercury"
        },
        {
          "symbol": "(",
          "hex": "#38BDF8",
          "name": "Earth"
        },
        {
          "symbol": ")",
          "hex": "#FB7185",
          "name": "Mars"
        },
        {
          "symbol": "*",
          "hex": "#F59E0B",
