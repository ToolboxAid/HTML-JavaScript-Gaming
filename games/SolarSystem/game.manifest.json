{
  "$schema": "tools/schemas/game.manifest.schema.json",
  "schema": "html-js-gaming.game-manifest",
  "version": 1,
  "game": {
    "id": "SolarSystem",
    "name": "Solar System",
    "folder": "SolarSystem"
  },
  "launch": {
    "directPath": "/games/SolarSystem/index.html"
  },
  "tools": {
    "palette-manager-v2": {
      "$schema": "tools/schemas/tools/palette-manager-v2.schema.json",
      "schema": "html-js-gaming.palette",
      "version": 1,
      "name": "Solar System Classic Palette",
      "source": "manifest",
      "swatches": [
        {
          "symbol": "!",
          "hex": "#030712",
          "name": "Space Background"
        },
        {
          "symbol": "#",
          "hex": "#DBEAFE",
          "name": "Frame and Text"
        },
        {
          "symbol": "$",
          "hex": "#334155",
          "name": "Orbits"
        },
        {
          "symbol": "%",
          "hex": "#FBBF24",
          "name": "Sun"
        },
        {
          "symbol": "&",
          "hex": "#9CA3AF",
          "name": "Mercury"
        },
        {
          "symbol": "(",
          "hex": "#38BDF8",
          "name": "Earth"
        },
        {
          "symbol": ")",
          "hex": "#FB7185",
          "name": "Mars"
        },
        {
          "symbol": "*",
          "hex": "#F59E0B",
          "name": "Jupiter"
        },
        {
          "symbol": "+",
          "hex": "#EAB308",
          "name": "Saturn"
        },
        {
          "symbol": ",",
          "hex": "#67E8F9",
          "name": "Uranus"
        },
        {
          "symbol": "-",
          "hex": "#60A5FA",
          "name": "Neptune"
        }
      ]
    },
    "asset-manager-v2": {
      "$schema": "tools/schemas/tools/asset-manager-v2.schema.json",
      "schema": "html-js-gaming.asset-manager-v2",
      "version": 1,
      "name": "Solar System Asset Manager V2 Registry",
      "source": "manifest",
      "assets": {
        "assets.image.preview.preview": {
          "path": "assets/images/preview.svg",
          "type": "image",
          "kind": "svg",
          "role": "preview",
          "source": "manifest"
        }
      }
    },
    "input-mapping-v2": {
      "$schema": "tools/schemas/tools/input-mapping-v2.schema.json",
      "toolId": "input-mapping-v2",
      "version": 1,
      "engineInputModel": "src/engine/input/InputMap",
      "actions": [
        {
          "action": "pause",
          "label": "Pause",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "KeyP",
              "label": "Keyboard KeyP Press",
              "engine": "KeyboardState"
            }
          ]
        },
        {
          "action": "toggleLabels",
          "label": "Toggle Labels",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "KeyL",
              "label": "Keyboard KeyL Press",
              "engine": "KeyboardState"
            }
          ]
        },
        {
          "action": "resetClock",
          "label": "Reset Clock",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "KeyR",
              "label": "Keyboard KeyR Press",
              "engine": "KeyboardState"
            }
          ]
        },
        {
          "action": "timeScale1",
          "label": "Time Scale 1x",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "Digit1",
              "label": "Keyboard Digit1 Press",
              "engine": "KeyboardState"
            }
          ]
        },
        {
          "action": "timeScale2",
          "label": "Time Scale 2x",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "Digit2",
              "label": "Keyboard Digit2 Press",
              "engine": "KeyboardState"
            }
          ]
        },
        {
          "action": "timeScale3",
          "label": "Time Scale 3x",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "Digit3",
              "label": "Keyboard Digit3 Press",
              "engine": "KeyboardState"
            }
          ]
        },
        {
          "action": "timeScale4",
          "label": "Time Scale 4x",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "Digit4",
              "label": "Keyboard Digit4 Press",
              "engine": "KeyboardState"
            }
          ]
        }
      ]
    }
  }
}
