{
  "$schema": "tools/schemas/game.manifest.schema.json",
  "schema": "html-js-gaming.game-manifest",
  "version": 1,
  "game": {
    "id": "GravityWell",
    "name": "Gravity Well",
    "folder": "GravityWell"
  },
  "launch": {
    "directPath": "/games/GravityWell/index.html",
    "workspaceManagerPath": "/tools/workspace-manager-v2/index.html?gameId=GravityWell",
    "workspaceManagerOptional": true
  },
  "tools": {
    "palette-manager-v2": {
      "$schema": "tools/schemas/tools/palette-manager-v2.schema.json",
      "schema": "html-js-gaming.palette",
      "version": 1,
      "name": "Gravity Well Palette",
      "source": "manifest",
      "swatches": [
        {
          "symbol": "!",
          "hex": "#081121",
          "name": "Background"
        },
        {
          "symbol": "#",
          "hex": "#1D4ED8",
          "name": "Gravity Blue"
        },
        {
          "symbol": "$",
          "hex": "#1E293B",
          "name": "Planet Shadow"
        },
        {
          "symbol": "%",
          "hex": "#244266",
          "name": "Arena Border"
        },
        {
          "symbol": "&",
          "hex": "#F8FAFC",
          "name": "Ship White"
        },
        {
          "symbol": "(",
          "hex": "#FBBF24",
          "name": "Thrust Amber"
        },
        {
          "symbol": ")",
          "hex": "#60A5FA",
          "name": "HUD Blue"
        },
        {
          "symbol": "*",
          "hex": "#CBD5E1",
          "name": "HUD Muted"
        },
        {
          "symbol": "+",
          "hex": "#38BDF8",
          "name": "Gravity Cyan"
        },
        {
          "symbol": "0",
          "hex": "#FB7185",
          "name": "Gravity Rose"
        }
      ]
    },
    "asset-manager-v2": {
      "$schema": "tools/schemas/tools/asset-manager-v2.schema.json",
      "schema": "html-js-gaming.asset-manager-v2",
      "version": 1,
      "name": "Gravity Well Asset Manager V2 Registry",
      "source": "manifest",
      "assets": {
        "assets.image.preview.preview": {
          "path": "assets/images/preview.svg",
          "type": "image",
          "kind": "svg",
          "role": "preview",
          "source": "manifest"
        }
      }
    },
    "input-mapping-v2": {
      "$schema": "tools/schemas/tools/input-mapping-v2.schema.json",
      "toolId": "input-mapping-v2",
      "version": 1,
      "engineInputModel": "src/engine/input/InputMap",
      "actions": [
        {
          "action": "rotateLeft",
          "label": "Rotate Left",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "ArrowLeft:KeyboardHold",
              "label": "Keyboard ArrowLeft Hold",
              "engine": "KeyboardState"
            }
          ]
        },
        {
          "action": "rotateRight",
          "label": "Rotate Right",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "ArrowRight:KeyboardHold",
              "label": "Keyboard ArrowRight Hold",
              "engine": "KeyboardState"
            }
          ]
        },
        {
          "action": "thrust",
          "label": "Thrust",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "ArrowUp:KeyboardHold",
              "label": "Keyboard ArrowUp Hold",
              "engine": "KeyboardState"
            }
          ]
        },
        {
          "action": "brake",
          "label": "Brake",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "Space:KeyboardHold",
              "label": "Keyboard Space Hold",
              "engine": "KeyboardState"
            }
          ]
        },
        {
          "action": "startRun",
          "label": "Start Run",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "Enter",
              "label": "Keyboard Enter Press",
              "engine": "KeyboardState"
            }
          ]
        },
        {
          "action": "recordRun",
          "label": "Record Run",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "KeyR",
              "label": "Keyboard KeyR Press",
              "engine": "KeyboardState"
            }
          ]
        },
        {
          "action": "playbackRun",
          "label": "Playback Run",
          "inputs": [
            {
              "source": "keyboard",
              "binding": "KeyP",
              "label": "Keyboard KeyP Press",
              "engine": "KeyboardState"
            }
          ]
        }
      ]
    }
  }
}
