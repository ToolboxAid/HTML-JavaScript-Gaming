{
  "schema": "html-js-gaming.game-manifest",
  "version": 1,
  "game": {
    "id": "Bouncing-ball",
    "name": "Bouncing Ball",
    "folder": "Bouncing-ball"
  },
  "launch": {
    "directPath": "/games/Bouncing-ball/index.html",
    "workspaceManagerPath": "/tools/Workspace%20Manager/index.html?gameId=Bouncing-ball&mount=game",
    "workspaceManagerOptional": true
  },
  "tools": {
    "primitive-skin-editor": {
      "skins": [
        {
          "id": "skin.main",
          "data": {
            "documentKind": "game-skin",
            "version": 1,
            "schema": "games.bouncing-ball.skin/1",
            "gameId": "Bouncing-ball",
            "name": "Bouncing Ball Classic Skin",
            "objects": {
              "background": {
                "color": "#05070a",
                "shape": "hud-color"
              },
              "wall": {
                "color": "#f4f4ef",
                "thickness": 18,
                "shape": "wall"
              },
              "ball": {
                "color": "#f4f4ef",
                "size": 22,
                "shape": "square"
              },
              "hudText": {
                "color": "#f4f4ef",
                "shape": "hud-color"
              },
              "hudMuted": {
                "color": "#9ba3b3",
                "shape": "hud-color"
              },
              "hudPanel": {
                "color": "#05070a",
                "shape": "hud-color"
              }
            },
            "entities": {}
          }
        }
      ],
      "schema": "html-js-gaming.tool.primitive-skin-editor",
      "version": 1,
      "name": "Primitive Skin Editor",
      "source": "manifest"
    },
    "palette-browser": {
      "schema": "html-js-gaming.tool.palette-browser",
      "version": 1,
      "name": "Palette Browser",
      "source": "manifest",
      "palette": {
        "schema": "html-js-gaming.palette",
        "version": 1,
        "name": "Bouncing Ball Palette",
        "source": "manifest-and-runtime-color-scan",
        "swatches": [
          {
            "symbol": "0",
            "hex": "#05070A",
            "name": "Color 1"
          },
          {
            "symbol": "1",
            "hex": "#F4F4EF",
            "name": "Color 2"
          },
          {
            "symbol": "2",
            "hex": "#9BA3B3",
            "name": "Color 3"
          }
        ]
      }
    }
  }
}
