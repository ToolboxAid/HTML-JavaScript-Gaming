{
  "$schema": "tools/schemas/game.manifest.schema.json",
  "schema": "html-js-gaming.game-manifest",
  "version": 1,
  "game": {
    "id": "Pong",
    "name": "Pong",
    "folder": "Pong",
    "gameData": {
      "launch": {
        "directPath": "/games/Pong/index.html",
        "workspaceManagerPath": "/tools/workspace-manager-v2/index.html?gameId=Pong",
        "workspaceManagerOptional": true
      }
    },
    "workspace": {
      "$schema": "tools/schemas/workspace.manifest.schema.json",
      "documentKind": "workspace-manifest",
      "schema": "html-js-gaming.project",
      "version": 1,
      "id": "workspace-manager-v2-Pong",
      "name": "Pong Workspace Manager V2 Context",
      "gameId": "Pong",
      "gameRoot": "games/Pong/",
      "assetsPath": "games/Pong/assets",
      "repoRoot": "HTML-JavaScript-Gaming",
      "repoPath": "C:/Users/davidq/Documents/GitHub/HTML-JavaScript-Gaming",
      "tools": {
        "palette-manager-v2": {
          "$schema": "tools/schemas/tools/palette-manager-v2.schema.json",
          "schema": "html-js-gaming.palette",
          "version": 1,
          "name": "Pong Classic Palette",
          "source": "manifest",
          "swatches": [
            {
              "symbol": "!",
              "hex": "#05070A",
              "name": "Background"
            },
            {
              "symbol": "#",
              "hex": "#F4F7FB",
              "name": "Ink / Paddles"
            },
            {
              "symbol": "$",
              "hex": "#A6B0BF",
              "name": "Muted HUD"
            },
            {
              "symbol": "%",
              "hex": "#7DE2FF",
              "name": "Accent"
            },
            {
              "symbol": "&",
              "hex": "#8BF0C8",
              "name": "Positive"
            },
            {
              "symbol": "(",
              "hex": "#FFD37D",
              "name": "Warning"
            },
            {
              "symbol": ")",
              "hex": "#FF9A9A",
              "name": "Danger"
            },
            {
              "symbol": "*",
              "hex": "#6A7482",
              "name": "Center Divider"
            }
          ]
        },
        "asset-manager-v2": {
          "$schema": "tools/schemas/tools/asset-manager-v2.schema.json",
          "schema": "html-js-gaming.asset-manager-v2",
          "version": 1,
          "name": "Pong Asset Manager V2 Registry",
          "source": "manifest",
          "assets": {
            "assets.image.preview.preview": {
              "path": "assets/images/preview.svg",
              "type": "image",
              "kind": "svg",
              "role": "preview",
              "source": "manifest"
            }
          }
        },
        "text2speach-V2": [
          {
            "id": "narrator-welcome",
            "name": "Narrator welcome",
            "text": "Welcome to Toolbox Aid. This is the default Text to Speech V2 sample line for previewing narration, prompts, and menu feedback.",
            "gender": "any",
            "language": "en-US",
            "voice": "mock-google-us-english",
            "voiceAge": "any",
            "volume": 1,
            "rate": 1,
            "pitch": 1,
            "queueMode": "replace",
            "characterPreset": "narrator",
            "ssmlLikePreset": "normal"
          },
          {
            "id": "hero-ready",
            "name": "Hero ready",
            "text": "Systems ready. The hero prompt is queued for an upbeat menu confirmation.",
            "gender": "male-preferred",
            "language": "en-GB",
            "voice": "mock-google-uk-english-male",
            "voiceAge": "teen",
            "volume": 1,
            "rate": 1.2,
            "pitch": 1.4,
            "queueMode": "append",
            "characterPreset": "dramatic",
            "ssmlLikePreset": "normal"
          },
          {
            "id": "alert-warning",
            "name": "Alert warning",
            "text": "Warning. Incoming hazard detected. Please confirm the next action.",
            "gender": "female-preferred",
            "language": "en-US",
            "voice": "mock-microsoft-zira",
            "voiceAge": "adult",
            "volume": 0.9,
            "rate": 1.3,
            "pitch": 0.9,
            "queueMode": "replace",
            "characterPreset": "alert",
            "ssmlLikePreset": "normal"
          }
        ]
      }
    }
  }
}
