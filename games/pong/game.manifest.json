{
  "$schema": "tools/schemas/game.manifest.schema.json",
  "schema": "html-js-gaming.game-manifest",
  "version": 1,
  "game": {
    "id": "Pong",
    "name": "Pong",
    "folder": "Pong"
  },
  "launch": {
    "directPath": "/games/Pong/index.html",
    "workspaceManagerPath": "/tools/workspace-manager-v2/index.html?gameId=Pong",
    "workspaceManagerOptional": true
  },
  "tools": {
    "palette-manager-v2": {
      "$schema": "tools/schemas/tools/palette-manager-v2.schema.json",
      "schema": "html-js-gaming.palette",
      "version": 1,
      "name": "Pong Classic Palette",
      "source": "manifest",
      "swatches": [
        {
          "symbol": "!",
          "hex": "#05070A",
          "name": "Background"
        },
        {
          "symbol": "#",
          "hex": "#F4F7FB",
          "name": "Ink / Paddles"
        },
        {
          "symbol": "$",
          "hex": "#A6B0BF",
          "name": "Muted HUD"
        },
        {
          "symbol": "%",
          "hex": "#7DE2FF",
          "name": "Accent"
        },
        {
          "symbol": "&",
          "hex": "#8BF0C8",
          "name": "Positive"
        },
        {
          "symbol": "(",
          "hex": "#FFD37D",
          "name": "Warning"
        },
        {
          "symbol": ")",
          "hex": "#FF9A9A",
          "name": "Danger"
        },
        {
          "symbol": "*",
          "hex": "#6A7482",
          "name": "Center Divider"
        }
      ]
    },
    "asset-manager-v2": {
      "$schema": "tools/schemas/tools/asset-manager-v2.schema.json",
      "schema": "html-js-gaming.asset-manager-v2",
      "version": 1,
      "name": "Pong Asset Manager V2 Registry",
      "source": "manifest",
      "assets": {
        "assets.image.preview.preview": {
          "path": "assets/images/preview1.svg",
          "type": "image",
          "kind": "svg",
          "role": "preview",
          "source": "manifest"
        }
      }
    },
    "input-mapping-v2": {
      "$schema": "tools/schemas/tools/input-mapping-v2.schema.json",
      "toolId": "input-mapping-v2",
      "version": 1,
      "engineInputModel": "src/engine/input/InputMap",
      "actions": [
        {
          "action": "cancel",
          "label": "Cancel",
          "inputs": []
        },
        {
          "action": "confirm",
          "label": "Confirm",
          "inputs": []
        },
        {
          "action": "fire",
          "label": "Fire",
          "inputs": []
        },
        {
          "action": "interact",
          "label": "Interact",
          "inputs": []
        },
        {
          "action": "jump",
          "label": "Jump",
          "inputs": []
        },
        {
          "action": "menu",
          "label": "Menu",
          "inputs": []
        },
        {
          "action": "moveDown",
          "label": "Move Down",
          "inputs": []
        },
        {
          "action": "moveLeft",
          "label": "Move Left",
          "inputs": []
        },
        {
          "action": "moveRight",
          "label": "Move Right",
          "inputs": []
        },
        {
          "action": "moveUp",
          "label": "Move Up",
          "inputs": []
        },
        {
          "action": "pause",
          "label": "Pause",
          "inputs": []
        },
        {
          "action": "primaryAction",
          "label": "Primary Action",
          "inputs": []
        },
        {
          "action": "rotateLeft",
          "label": "Rotate Left",
          "inputs": []
        },
        {
          "action": "rotateRight",
          "label": "Rotate Right",
          "inputs": []
        },
        {
          "action": "secondaryAction",
          "label": "Secondary Action",
          "inputs": []
        },
        {
          "action": "select",
          "label": "Select",
          "inputs": []
        },
        {
          "action": "start",
          "label": "Start",
          "inputs": []
        },
        {
          "action": "thrust",
          "label": "Thrust",
          "inputs": []
        }
      ]
    }
  }
}
