            "gameId": "Pong",
            "name": "Pong Classic Skin",
            "objects": {
              "background": {
                "color": "#05070a",
                "shape": "hud-color"
              },
              "paddle": {
                "color": "#f4f7fb",
                "width": 14,
                "shape": "rectangle"
              },
              "ball": {
                "color": "#f4f7fb",
                "radius": 8,
                "shape": "circle"
              },
              "hudInk": {
                "color": "#f4f7fb",
                "shape": "hud-color"
              },
              "hudMuted": {
