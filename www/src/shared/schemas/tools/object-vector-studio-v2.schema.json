{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "object-vector-studio-v2.schema.json",
  "title": "Object Vector Studio V2 Durable Asset Payload",
  "description": "Strict durable asset data for Object Vector Studio V2. Runtime startup state and palette resources are loaded separately and are not stored in this payload.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "toolId", "name", "objects"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "toolId": {
      "const": "object-vector-studio-v2"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "objects": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/object"
      }
    }
  },
  "$defs": {
    "object": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "tags", "shapes"],
      "default": {
        "id": "object.game.object",
        "name": "Object",
        "objectOrigin": { "x": 0, "y": 0 },
        "tags": [],
        "shapes": []
      },
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^object\\.[a-z0-9-]+\\.[a-z0-9][a-z0-9-]*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "$ref": "#/$defs/tags"
        },
        "objectOrigin": {
          "$ref": "#/$defs/point2d"
        },
        "baseObjectId": {
          "type": "string",
          "minLength": 1
        },
        "shapes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/shape"
          }
        },
        "states": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/objectState"
          }
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "objectState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "frames"],
      "properties": {
        "id": {
          "type": "string",
          "enum": ["idle", "move", "active", "inactive", "damaged", "destroyed"]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "frames": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/animationFrame"
          }
        }
      }
    },
    "animationFrame": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "order", "durationFrames", "shapeOverrides"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "order": {
          "type": "integer",
          "minimum": 0
        },
        "durationFrames": {
          "type": "integer",
          "minimum": 1
        },
        "shapeOverrides": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/shapeFrameOverride"
          }
        }
      }
    },
    "shapeFrameOverride": {
      "type": "object",
      "additionalProperties": false,
      "required": ["shapeIndex"],
      "properties": {
        "shapeIndex": {
          "description": "Zero-based local sorted shape row index for the shape this frame override targets.",
          "type": "integer",
          "minimum": 0
        },
        "visible": {
          "type": "boolean"
        },
        "transform": {
          "$ref": "#/$defs/transform"
        }
      }
    },
    "shape": {
      "oneOf": [
        {
          "$ref": "#/$defs/rectangleShape"
        },
        {
          "$ref": "#/$defs/squareShape"
        },
        {
          "$ref": "#/$defs/circleShape"
        },
        {
          "$ref": "#/$defs/ellipseShape"
        },
        {
          "$ref": "#/$defs/lineShape"
        },
        {
          "$ref": "#/$defs/triangleShape"
        },
        {
          "$ref": "#/$defs/polygonShape"
        },
        {
          "$ref": "#/$defs/polylineShape"
        },
        {
          "$ref": "#/$defs/arcShape"
        },
        {
          "$ref": "#/$defs/textShape"
        }
      ]
    },
    "shapeCommon": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool", "order", "visible", "locked", "geometry", "style", "transform"],
      "default": {
        "tool": "polygon",
        "order": 0,
        "visible": true,
        "locked": false,
        "geometry": {},
        "style": {
          "fill": "#ffffff",
          "stroke": "#ffffff",
          "strokeWidth": 3,
          "roundingRadius": 4,
          "pointStyle": "square",
          "startPointStyle": "square",
          "endPointStyle": "square",
          "fillOpacity": 1,
          "strokeOpacity": 1
        },
        "transform": {
          "x": 0,
          "y": 0,
          "rotation": 0,
          "scaleX": 1,
          "scaleY": 1
        }
      },
      "properties": {
        "tool": {
          "description": "Editor and runtime shape/tool kind. Triangle is polygon geometry authored by the triangle tool. Square is rectangle geometry authored with equal width and height. Polyline is open point-list geometry.",
          "type": "string",
          "enum": ["triangle", "rectangle", "square", "circle", "ellipse", "line", "polygon", "polyline", "arc", "text"]
        },
        "order": {
          "type": "integer",
          "minimum": 0
        },
        "visible": {
          "type": "boolean"
        },
        "locked": {
          "type": "boolean"
        },
        "groupId": {
          "type": "string",
          "minLength": 1
        },
        "geometry": {
          "type": "object"
        },
        "style": {
          "$ref": "#/$defs/style"
        },
        "transform": {
          "$ref": "#/$defs/transform"
        }
      }
    },
    "rectangleShape": {
      "allOf": [
        {
          "$ref": "#/$defs/shapeCommon"
        },
        {
          "type": "object",
          "properties": {
            "tool": {
              "const": "rectangle"
            },
            "geometry": {
              "$ref": "#/$defs/rectangleGeometry"
            }
          }
        }
      ]
    },
    "squareShape": {
      "allOf": [
        {
          "$ref": "#/$defs/shapeCommon"
        },
        {
          "type": "object",
          "properties": {
            "tool": {
              "const": "square"
            },
            "geometry": {
              "$ref": "#/$defs/rectangleGeometry"
            }
          }
        }
      ]
    },
    "circleShape": {
      "allOf": [
        {
          "$ref": "#/$defs/shapeCommon"
        },
        {
          "type": "object",
          "properties": {
            "tool": {
              "const": "circle"
            },
            "geometry": {
              "$ref": "#/$defs/circleGeometry"
            }
          }
        }
      ]
    },
    "ellipseShape": {
      "allOf": [
        {
          "$ref": "#/$defs/shapeCommon"
        },
        {
          "type": "object",
          "properties": {
            "tool": {
              "const": "ellipse"
            },
            "geometry": {
              "$ref": "#/$defs/ellipseGeometry"
            }
          }
        }
      ]
    },
    "lineShape": {
      "allOf": [
        {
          "$ref": "#/$defs/shapeCommon"
        },
        {
          "type": "object",
          "properties": {
            "tool": {
              "const": "line"
            },
            "geometry": {
              "$ref": "#/$defs/lineGeometry"
            }
          }
        }
      ]
    },
    "polygonShape": {
      "allOf": [
        {
          "$ref": "#/$defs/shapeCommon"
        },
        {
          "type": "object",
          "properties": {
            "tool": {
              "const": "polygon"
            },
            "geometry": {
              "$ref": "#/$defs/polygonGeometry"
            }
          }
        }
      ]
    },
    "polylineShape": {
      "allOf": [
        {
          "$ref": "#/$defs/shapeCommon"
        },
        {
          "type": "object",
          "properties": {
            "tool": {
              "const": "polyline"
            },
            "geometry": {
              "$ref": "#/$defs/polylineGeometry"
            }
          }
        }
      ]
    },
    "triangleShape": {
      "allOf": [
        {
          "$ref": "#/$defs/shapeCommon"
        },
        {
          "type": "object",
          "properties": {
            "tool": {
              "const": "triangle"
            },
            "geometry": {
              "$ref": "#/$defs/triangleGeometry"
            }
          }
        }
      ]
    },
    "arcShape": {
      "allOf": [
        {
          "$ref": "#/$defs/shapeCommon"
        },
        {
          "type": "object",
          "properties": {
            "tool": {
              "const": "arc"
            },
            "geometry": {
              "$ref": "#/$defs/arcGeometry"
            }
          }
        }
      ]
    },
    "textShape": {
      "allOf": [
        {
          "$ref": "#/$defs/shapeCommon"
        },
        {
          "type": "object",
          "properties": {
            "tool": {
              "const": "text"
            },
            "geometry": {
              "$ref": "#/$defs/textGeometry"
            }
          }
        }
      ]
    },
    "style": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fill", "stroke", "strokeWidth", "fillOpacity", "strokeOpacity"],
      "default": {
        "fill": "#ffffff",
        "stroke": "#ffffff",
        "strokeWidth": 3,
        "pointStyle": "square",
        "startPointStyle": "square",
        "endPointStyle": "square",
        "fillOpacity": 1,
        "strokeOpacity": 1
      },
      "properties": {
        "fill": {
          "type": "string",
          "minLength": 1
        },
        "stroke": {
          "type": "string",
          "minLength": 1
        },
        "strokeWidth": {
          "type": "number",
          "minimum": 0
        },
        "strokeLinecap": {
          "type": "string",
          "enum": ["round", "square"]
        },
        "roundingRadius": {
          "type": "number",
          "minimum": 0
        },
        "pointStyle": {
          "type": "string",
          "enum": ["round", "square"]
        },
        "startPointStyle": {
          "type": "string",
          "enum": ["round", "square"]
        },
        "endPointStyle": {
          "type": "string",
          "enum": ["round", "square"]
        },
        "pointRounding": {
          "type": "array",
          "items": {
            "type": "boolean"
          }
        },
        "fillOpacity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "strokeOpacity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "transform": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "rotation", "scaleX", "scaleY"],
      "default": {
        "x": 0,
        "y": 0,
        "rotation": 0,
        "scaleX": 1,
        "scaleY": 1
      },
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "rotation": {
          "type": "number"
        },
        "scaleX": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "scaleY": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "point2d": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "default": { "x": 0, "y": 0 },
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        }
      }
    },
    "rectangleGeometry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "width", "height"],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "width": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "height": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "circleGeometry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cx", "cy", "r"],
      "properties": {
        "cx": {
          "type": "number"
        },
        "cy": {
          "type": "number"
        },
        "r": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "ellipseGeometry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cx", "cy", "rx", "ry"],
      "properties": {
        "cx": {
          "type": "number"
        },
        "cy": {
          "type": "number"
        },
        "rx": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "ry": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "lineGeometry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["point1", "point2"],
      "properties": {
        "point1": {
          "$ref": "#/$defs/point2d"
        },
        "point2": {
          "$ref": "#/$defs/point2d"
        }
      }
    },
    "polygonGeometry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["points"],
      "properties": {
        "points": {
          "type": "array",
          "minItems": 4,
          "items": {
            "$ref": "#/$defs/point2d"
          }
        }
      }
    },
    "polylineGeometry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["points"],
      "properties": {
        "points": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/point2d"
          }
        }
      }
    },
    "triangleGeometry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["points"],
      "properties": {
        "points": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "$ref": "#/$defs/point2d"
          }
        }
      }
    },
    "arcGeometry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cx", "cy", "r", "startAngle", "endAngle"],
      "properties": {
        "cx": {
          "type": "number"
        },
        "cy": {
          "type": "number"
        },
        "r": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "startAngle": {
          "type": "number"
        },
        "endAngle": {
          "type": "number"
        }
      }
    },
    "textGeometry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "fontSize", "text"],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "fontSize": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "text": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
