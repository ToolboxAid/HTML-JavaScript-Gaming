{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "src/shared/schemas/tools/palette-browser.schema.json",
  "title": "Palette Browser Direct Palette Payload",
  "type": "object",
  "required": ["schema", "version", "name", "swatches"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "schema": {
      "type": "string",
      "const": "html-js-gaming.palette"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "sourceId": {
      "type": "string",
      "minLength": 1
    },
    "locked": {
      "type": "boolean"
    },
    "swatches": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/swatch"
      }
    }
  },
  "$defs": {
    "swatch": {
      "type": "object",
      "required": ["key", "hex", "name"],
      "additionalProperties": false,
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1
        },
        "hex": {
          "type": "string",
          "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{8})$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "description": "Payload-only Palette Browser schema for direct palette JSON; rejects tool, workspace, game, and sample wrappers."
}
