{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "src/shared/schemas/tools/svg-asset-studio.schema.json",
  "title": "SVG Asset Studio Payload",
  "type": "object",
  "required": [
    "vectorAssetDocument"
  ],
  "additionalProperties": false,
  "properties": {
    "vectorAssetDocument": {
      "$ref": "#/$defs/jsonValue"
    }
  },
  "$defs": {
    "jsonValue": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "integer"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/jsonArray"
        },
        {
          "$ref": "#/$defs/jsonObject"
        }
      ]
    },
    "jsonArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/jsonValue"
      }
    },
    "jsonObject": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^.*$": {
          "$ref": "#/$defs/jsonValue"
        }
      },
      "propertyNames": {
        "type": "string"
      }
    }
  }
}
