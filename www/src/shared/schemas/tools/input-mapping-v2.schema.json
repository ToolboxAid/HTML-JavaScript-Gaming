{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "src/shared/schemas/tools/input-mapping-v2.schema.json",
  "title": "Input Mapping V2 Tool Payload",
  "description": "Validated Input Mapping V2 payload for game manifest and Workspace Manager V2 toolState contexts.",
  "type": "object",
  "required": ["toolId", "version", "engineInputModel", "actions"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "toolId": {
      "const": "input-mapping-v2"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "engineInputModel": {
      "type": "string",
      "minLength": 1
    },
    "actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/actionMapping"
      }
    }
  },
  "$defs": {
    "actionMapping": {
      "type": "object",
      "required": ["action", "label", "inputs"],
      "additionalProperties": false,
      "properties": {
        "action": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "inputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/inputBinding"
          }
        }
      }
    },
    "inputBinding": {
      "type": "object",
      "required": ["source", "binding", "label", "engine"],
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "enum": ["keyboard", "mouse", "gamepad"]
        },
        "binding": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "engine": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
