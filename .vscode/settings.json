// scripts/todo tree.txt
{
    "todo-tree.general.tags": [
        "BUG",
        "TODO",

        "[ ]",
        "[.]",
        "[-]",
        "[x]",
        "[X]",
        "[!]",
    ],
    "todo-tree.highlights.customHighlight": {
        "BUG": {
            "icon": "bug",
            "type": "line",
            "foreground": "white",
            "background": "#a63a50",
            "iconColour": "#a63a50",
        },
        "TODO": {
            "icon": "circle",
            "type": "line",
            "foreground": "white",
            "background": "#000000",
            "iconColour": "#000000",
        },
        "[ ]": {
            "icon": "circle",
            "type": "line",
            "foreground": "white",
            "background": "#000000",
            "iconColour": "#000000",
        },
        "[.]": {
            "icon": "loading",
            "type": "line",
            "foreground": "white",
            "background": "#bd9b20",
            "iconColour": "#bd9b20",
        },
        "[-]": {
            "icon": "remove-close",
            "type": "line",
            "foreground": "white",
            "background": "#b45f8a",
            "iconColour": "#b45f8a",
        },

        "[!]": {
            "icon": "blocked",
            "type": "line",
            "foreground": "white",
            "background": "#73508f",
            "iconColour": "#73508f",
        },
                
        "[x]": {
            "icon": "check-circle",
            "type": "line",
            "foreground": "white",
            "background": "#2f6b57",
            "iconColour": "#2f6b57",
        },
        "[X]": {
            "icon": "check-circle",
            "type": "line",
            "foreground": "white",
            "background": "#2f6b57",
            "iconColour": "#2f6b57",
        },        


    },    
    "todo-tree.tree.showBadges": true,
    "editor.quickSuggestions": {
        "other": true,
        "comments": true,
        "strings": true
    },
    "editor.suggestOnTriggerCharacters": true,
    "editor.suggestSelection": "first",
    "editor.tabCompletion": "on",
    "javascript.suggest.autoImports": true,
    "typescript.suggest.autoImports": true,
    "html.suggest.angular1": true,
    "html.suggest.ionic": true
}
