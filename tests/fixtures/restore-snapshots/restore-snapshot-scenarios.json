      "expectedErrors": ["RESTORE_SNAPSHOT_VERSION_COMPATIBILITY_INVALID"]
    },
    {
      "name": "invalid restored timestamp",
      "overrides": {
        "restoredAt": "not-a-date"
      },
      "expectedErrors": ["RESTORE_SNAPSHOT_RESTORED_AT_INVALID"]
    },
    {
      "name": "backup snapshot owner mismatch",
      "overrides": {
        "backupSnapshot": {
          "ownerId": "user.other"
        }
      },
      "expectedErrors": ["RESTORE_SNAPSHOT_OWNER_BACKUP_SNAPSHOT_MISMATCH"]
    },
    {
      "name": "version compatibility owner mismatch",
      "overrides": {
        "versionCompatibility": {
          "ownerId": "user.other"
        }
      },
      "expectedErrors": ["RESTORE_SNAPSHOT_OWNER_COMPATIBILITY_MISMATCH"]
    },
    {
      "name": "target release project mismatch",
      "overrides": {
        "targetRelease": {
          "projectId": "project.other"
        }
      },
      "expectedErrors": ["RESTORE_SNAPSHOT_PROJECT_TARGET_RELEASE_MISMATCH"]
    },
    {
      "name": "backup target release mismatch",
      "overrides": {
        "backupSnapshot": {
          "releaseId": "release.game.other.2"
        }
      },
      "expectedErrors": ["RESTORE_SNAPSHOT_RELEASE_BACKUP_TARGET_MISMATCH"]
    },
    {
      "name": "version compatibility release mismatch",
      "overrides": {
        "versionCompatibility": {
          "releaseId": "release.game.other.2"
        }
      },
      "expectedErrors": ["RESTORE_SNAPSHOT_RELEASE_COMPATIBILITY_MISMATCH"]
    },
    {
      "name": "publish compatibility mismatch",
      "overrides": {
        "versionCompatibility": {
