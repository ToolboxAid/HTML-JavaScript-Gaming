  },
  "validRestoreSnapshots": [
    {
      "name": "compatible restore snapshot",
      "overrides": {
        "restoreSnapshotId": "restore-snapshot.alpha.compatible"
      },
      "expectedErrors": []
    },
    {
      "name": "deprecated compatibility restore snapshot",
      "overrides": {
        "restoreSnapshotId": "restore-snapshot.alpha.deprecated",
        "versionCompatibility": {
          "compatibilityState": "deprecated"
        },
        "restoreNotes": "Deprecated compatibility may still restore while metadata remains linked."
      },
      "expectedErrors": []
    }
  ],
  "invalidRestoreSnapshots": [
    {
      "name": "missing owner",
      "overrides": {
        "ownerId": ""
      },
      "expectedErrors": ["RESTORE_SNAPSHOT_OWNER_REQUIRED"]
    },
    {
      "name": "missing project",
      "overrides": {
        "projectId": ""
      },
      "expectedErrors": ["RESTORE_SNAPSHOT_PROJECT_REQUIRED"]
    },
    {
      "name": "missing backup snapshot",
      "removeFields": ["backupSnapshot"],
      "expectedErrors": ["RESTORE_SNAPSHOT_BACKUP_SNAPSHOT_REQUIRED"]
    },
    {
      "name": "missing target release",
      "removeFields": ["targetRelease"],
      "expectedErrors": ["RESTORE_SNAPSHOT_TARGET_RELEASE_REQUIRED"]
    },
    {
      "name": "missing version compatibility",
      "removeFields": ["versionCompatibility"],
      "expectedErrors": ["RESTORE_SNAPSHOT_VERSION_COMPATIBILITY_REQUIRED"]
    },
    {
      "name": "invalid backup snapshot",
      "overrides": {
        "backupSnapshot": {
          "snapshotVersion": 0
