      },
      "expectedErrors": ["RESTORE_SNAPSHOT_BACKUP_SNAPSHOT_INVALID"]
    },
    {
      "name": "invalid target release",
      "overrides": {
        "targetRelease": {
          "version": 0
        }
      },
      "expectedErrors": ["RESTORE_SNAPSHOT_TARGET_RELEASE_INVALID"]
    },
    {
      "name": "invalid version compatibility",
