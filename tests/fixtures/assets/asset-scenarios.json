  "accessChecks": [
    {
      "name": "private asset owner can view",
      "actorId": "user.owner",
      "projectRole": "owner",
      "permission": "view",
      "asset": {
        "assetId": "asset.private",
        "assetType": "image",
        "ownerId": "user.owner",
        "projectId": "project.private",
        "visibility": "private",
        "version": 1,
        "status": "active",
        "metadata": {
          "filePath": "assets/images/private.png",
          "width": 32,
          "height": 32
        },
        "exportFormats": ["image-file"]
      },
      "project": {
        "id": "project.private",
        "ownerId": "user.owner",
        "state": "active",
        "visibility": "private"
      },
      "expected": true
    },
    {
      "name": "private asset ungranted user cannot view",
      "actorId": "user.other",
      "projectRole": "viewer",
      "permission": "view",
      "asset": {
        "assetId": "asset.private",
        "assetType": "image",
        "ownerId": "user.owner",
        "projectId": "project.private",
        "visibility": "private",
        "version": 1,
        "status": "active",
        "metadata": {
          "filePath": "assets/images/private.png",
          "width": 32,
          "height": 32
        },
        "exportFormats": ["image-file"]
      },
      "project": {
        "id": "project.private",
        "ownerId": "user.owner",
        "state": "active",
        "visibility": "private"
      },
      "expected": false
    },
    {
      "name": "project asset granted collaborator can edit",
      "actorId": "user.collaborator",
      "projectRole": "collaborator",
      "permission": "edit",
      "grantedProjectIds": ["project.active"],
      "grantedScopes": ["project"],
      "asset": {
        "assetId": "asset.project",
        "assetType": "palette",
        "ownerId": "user.owner",
        "projectId": "project.active",
        "visibility": "project",
        "version": 1,
        "status": "active",
        "metadata": {
          "swatchCount": 2
        },
        "exportFormats": ["palette-json"]
      },
      "project": {
        "id": "project.active",
        "ownerId": "user.owner",
        "state": "active",
        "visibility": "project"
      },
      "expected": true
    },
    {
      "name": "viewer cannot edit asset",
      "actorId": "user.viewer",
      "projectRole": "viewer",
      "permission": "edit",
      "grantedProjectIds": ["project.active"],
      "grantedScopes": ["project"],
      "asset": {
        "assetId": "asset.project",
        "assetType": "palette",
        "ownerId": "user.owner",
        "projectId": "project.active",
        "visibility": "project",
        "version": 1,
        "status": "active",
        "metadata": {
          "swatchCount": 2
        },
        "exportFormats": ["palette-json"]
      },
      "project": {
        "id": "project.active",
        "ownerId": "user.owner",
        "state": "active",
        "visibility": "project"
      },
      "expected": false
    },
    {
      "name": "marketplace asset is visible",
