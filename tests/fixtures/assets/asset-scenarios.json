      "projectRole": "viewer",
      "permission": "view",
      "asset": {
        "assetId": "asset.marketplace",
        "assetType": "audio",
        "ownerId": "user.owner",
        "projectId": "project.marketplace",
        "visibility": "marketplace",
        "version": 1,
        "status": "active",
        "metadata": {
          "filePath": "assets/audio/coin.wav",
          "durationMs": 300
        },
        "exportFormats": ["audio-file", "metadata-json"]
      },
      "project": {
        "id": "project.marketplace",
        "ownerId": "user.owner",
        "state": "marketplace",
        "visibility": "public"
      },
      "expected": true
    },
    {
      "name": "archived asset cannot be edited by default",
      "actorId": "user.owner",
      "projectRole": "owner",
      "permission": "edit",
      "asset": {
        "assetId": "asset.archived",
        "assetType": "vector",
        "ownerId": "user.owner",
        "projectId": "project.active",
        "visibility": "private",
        "version": 2,
        "status": "archived",
        "metadata": {
          "vectorFormat": "svg"
        },
        "exportFormats": ["svg"]
      },
      "project": {
        "id": "project.active",
        "ownerId": "user.owner",
        "state": "active",
        "visibility": "private"
      },
      "expected": false
    },
    {
      "name": "archived asset can be edited when policy allows",
      "actorId": "user.owner",
      "projectRole": "owner",
      "permission": "edit",
      "policy": {
        "allowArchivedAssetEdit": true
      },
      "asset": {
        "assetId": "asset.archived",
        "assetType": "vector",
        "ownerId": "user.owner",
        "projectId": "project.active",
        "visibility": "private",
        "version": 2,
        "status": "archived",
        "metadata": {
          "vectorFormat": "svg"
        },
        "exportFormats": ["svg"]
      },
      "project": {
        "id": "project.active",
        "ownerId": "user.owner",
        "state": "active",
        "visibility": "private"
      },
      "expected": true
    }
  ]
